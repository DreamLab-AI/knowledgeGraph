#
# Chimera Prime Workstream 1.4: SPARQL Verification Query
# Purpose: Verify complete removal of dt:is-subclass-of from ontology
# Expected Result: 0 results (empty result set)
#

PREFIX dt: <http://example.org/dt#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# ==============================================================================
# QUERY 1: Find ANY remaining dt:is-subclass-of property usage
# ==============================================================================

SELECT DISTINCT ?subject ?predicate ?object
WHERE {
    {
        # Direct usage as predicate
        ?subject dt:is-subclass-of ?object .
        BIND(dt:is-subclass-of AS ?predicate)
    }
    UNION
    {
        # Usage in owl:Restriction patterns (most common case)
        ?subject owl:onProperty dt:is-subclass-of .
        ?subject ?predicate ?object .
        FILTER(?predicate != rdf:type)
    }
    UNION
    {
        # Usage in property definitions or references
        ?subject ?predicate dt:is-subclass-of .
        FILTER(?predicate != owl:inverseOf)
        FILTER(?predicate != rdfs:subPropertyOf)
    }
    UNION
    {
        # Check if property definition still exists
        dt:is-subclass-of ?predicate ?object .
    }
}
ORDER BY ?subject ?predicate ?object

# Expected: 0 results after successful refactoring

