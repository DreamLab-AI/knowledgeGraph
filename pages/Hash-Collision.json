v>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-1-4\">\n<div class=\"block-content\">**Semantic Classification**</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-2-0\">\n<div class=\"block-content\">owl:class:: bc:HashCollision</div>\n</div>\n<div class=\"block\" data-id=\"block-2-1\">\n<div class=\"block-content\">owl:physicality:: VirtualEntity</div>\n</div>\n<div class=\"block\" data-id=\"block-2-2\">\n<div class=\"block-content\">owl:role:: Object</div>\n</div>\n<div class=\"block\" data-id=\"block-2-3\">\n<div class=\"block-content\">owl:inferred-class:: bc:VirtualObject</div>\n</div>\n<div class=\"block\" data-id=\"block-2-4\">\n<div class=\"block-content\"></div>\n</div>\n<div class=\"block\" data-id=\"block-2-5\">\n<div class=\"block-content\"></div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-1-5\">\n<div class=\"block-content\">#### Relationships</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"hash-collision-relationships\">\n<div class=\"block-content\"></div>\n</div>\n<div class=\"block\" data-id=\"block-2-1\">\n<div class=\"block-content\"></div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-1-6\">\n<div class=\"block-content\">#### OWL Axioms</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"hash-collision-owl-axioms\">\n<div class=\"block-content\"></div>\n</div>\n<div class=\"block\" data-id=\"block-2-1\">\n<div class=\"block-content\"></div>\n</div>\n<div class=\"block\" data-id=\"block-2-2\">\n<div class=\"block-content\">```clojure</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-3-0\">\n<div class=\"block-content\">Prefix(:=&lt;http://metaverse-ontology.org/blockchain#&gt;)</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-0-1\">\n<div class=\"block-content\">Import(&lt;http://metaverse-ontology.org/blockchain/core&gt;)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-2\">\n<div class=\"block-content\">Declaration(Class(:HashCollision))</div>\n</div>\n<div class=\"block\" data-id=\"block-0-3\">\n<div class=\"block-content\">SubClassOf(:HashCollision :CryptographicPrimitive)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-4\">\n<div class=\"block-content\">SubClassOf(:HashCollision :BlockchainEntity)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-5\">\n<div class=\"block-content\">SubClassOf(:HashCollision</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-2-0\">\n<div class=\"block-content\">(ObjectSomeValuesFrom :partOf :Blockchain))</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-0-6\">\n<div class=\"block-content\">SubClassOf(:HashCollision</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-2-0\">\n<div class=\"block-content\">(ObjectSomeValuesFrom :hasProperty :Property))</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-0-7\">\n<div class=\"block-content\">DataPropertyAssertion(:hasIdentifier :HashCollision &quot;BC-0046&quot;^^xsd:string)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-8\">\n<div class=\"block-content\">DataPropertyAssertion(:hasAuthorityScore :HashCollision &quot;1.0&quot;^^xsd:decimal)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-9\">\n<div class=\"block-content\">DataPropertyAssertion(:isFoundational :HashCollision &quot;true&quot;^^xsd:boolean)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-10\">\n<div class=\"block-content\">ObjectPropertyAssertion(:enablesFeature :HashCollision :BlockchainFeature)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-11\">\n<div class=\"block-content\">ObjectPropertyAssertion(:relatesTo :HashCollision :RelatedConcept)</div>\n</div>\n<div class=\"block\" data-id=\"block-0-12\">\n<div class=\"block-content\">AnnotationAssertion(rdfs:label :HashCollision &quot;Hash Collision&quot;@en)</div>\n</div>\n<div class=\"block\" data-id=\