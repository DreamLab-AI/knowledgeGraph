ta-id=\"block-4-0\">\n<div class=\"block-content\">output += f&quot;{file}\\n&quot;</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-2-6\">\n<div class=\"block-content\">log_output(output, clearlog=True)</div>\n</div>\n<div class=\"block\" data-id=\"block-2-7\">\n<div class=\"block-content\">return output</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-1-7\">\n<div class=\"block-content\"># Define the search term</div>\n</div>\n<div class=\"block\" data-id=\"block-1-8\">\n<div class=\"block-content\">search_term = &quot;public:: true&quot;</div>\n</div>\n<div class=\"block\" data-id=\"block-1-9\">\n<div class=\"block-content\"># Execute the search and log the result</div>\n</div>\n<div class=\"block\" data-id=\"block-1-10\">\n<div class=\"block-content\">result = list_files_containing_term(search_term)</div>\n</div>\n<div class=\"block\" data-id=\"block-1-11\">\n<div class=\"block-content\">print(result)</div>\n</div>\n<div class=\"block\" data-id=\"block-1-12\">\n<div class=\"block-content\">```</div>\n</div>\n<div class=\"block\" data-id=\"block-1-13\">\n<div class=\"block-content\">{{evalparent}}</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-0-1\">\n<div class=\"block-content\">```python</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-1-0\">\n<div class=\"block-content\">import js</div>\n</div>\n<div class=\"block\" data-id=\"block-1-1\">\n<div class=\"block-content\"># Helper function to convert object to a readable format</div>\n</div>\n<div class=\"block\" data-id=\"block-1-2\">\n<div class=\"block-content\">def props(title, obj):</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-2-0\">\n<div class=\"block-content\">print(&quot;---------------------------\\n&quot;)</div>\n</div>\n<div class=\"block\" data-id=\"block-2-1\">\n<div class=\"block-content\">try:</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-4-0\">\n<div cl