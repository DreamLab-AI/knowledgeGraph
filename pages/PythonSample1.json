  "html": "<h1>PythonSample1</h1>\n<div class=\"blocks\">\n<div class=\"block\" data-id=\"block-0-0\">\n<div class=\"block-content\">```javascript</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-1-0\">\n<div class=\"block-content\">import js</div>\n</div>\n<div class=\"block\" data-id=\"block-1-1\">\n<div class=\"block-content\"># Helper function to convert object to a readable format</div>\n</div>\n<div class=\"block\" data-id=\"block-1-2\">\n<div class=\"block-content\">def props(title, obj):</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-2-0\">\n<div class=\"block-content\">print(&quot;---------------------------\\n&quot;)</div>\n</div>\n<div class=\"block\" data-id=\"block-2-1\">\n<div class=\"block-content\">try:</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-4-0\">\n<div class=\"block-content\">keys = obj.object_keys()</div>\n</div>\n<div class=\"block\" data-id=\"block-4-1\">\n<div class=\"block-content\">vals = obj.object_values()</div>\n</div>\n<div class=\"block\" data-id=\"block-4-2\">\n<div class=\"block-content\">output = title + &quot; Objects\\n&quot;</div>\n</div>\n<div class=\"block\" data-id=\"block-4-3\">\n<div class=\"block-content\">for ctr in range(len(keys)):</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-6-0\">\n<div class=\"block-content\">output += f&quot;{str(keys[ctr]): &lt;12}  =&gt;  {str(vals[ctr]): &lt;40}\\n&quot;</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-2-2\">\n<div class=\"block-content\">except:</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-4-0\">\n<div class=\"block-content\">output = &quot;Not an object&quot;</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-2-3\">\n<div class=\"block-content\">print(output)</div>\n</div>\n<div class=\"block\" data-id=\"block-2-4\">\n<div class=\"block-content\">return output</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-1-3\">\n<div class=\"block-content\"># Function to log output to a specific Logseq page</div>\n</div>\n<div class=\"block\" data-id=\"block-1-4\">\n<div class=\"block-content\">def log_output(content, clearlog=False):</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-2-0\">\n<div class=\"block-content\">import datetime</div>\n</div>\n<div class=\"block\" data-id=\"block-2-1\">\n<div class=\"block-content\">output_page = &quot;Execution Log&quot;  # API always uses lower case page names</div>\n</div>\n<div class=\"block\" data-id=\"block-2-2\">\n<div class=\"block-content\">if clearlog:</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-4-0\">\n<div class=\"block-content\">logpage = js.logseq.api.get_page(output_page.lower())</div>\n</div>\n<div class=\"block\" data-id=\"block-4-1\">\n<div class=\"block-content\">blocks = js.logseq.api.get_page_blocks_tree(logpage.uuid)</div>\n</div>\n<div class=\"block\" data-id=\"block-4-2\">\n<div class=\"block-content\">for block in blocks:</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-6-0\">\n<div class=\"block-content\">js.logseq.api.remove_block(block.uuid)</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-2-3\">\n<div class=\"block-content\">js.logseq.api.append_block_in_page(</div>\n<div class=\"block-children\">\n<div class=\"block\" data-id=\"block-4-0\">\n<div class=\"block-content\">output_page,</div>\n</div>\n<div class=\"block\" data-id=\"block-4-1\">\n<div class=\"block-content\">str(datetime.datetime.now())[:19] + &quot; =&gt; &quot; + content)</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-2-4\">\n<div class=\"block-content\">return &quot;Done&quot;</div>\n</div>\n</div>\n</div>\n<div class=\"block\" data-id=\"block-1-5\">\n<div class=\"block-content\"># Function to list files containing the specified term</div>\n</div>\n<div class=