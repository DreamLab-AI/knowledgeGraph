dt:implemented-by a owl:ObjectProperty ;
    rdfs:label "implemented by" .

rb:Robot a owl:Class ;
    rdfs:label "Robot"@en ;
    dt:authorityScore 1.0 ;
    dt:maturity "mature" ;
    dcterms:identifier "RB-0001" ;
    rdfs:comment "A robot is an actuated mechanism programmable in two or more axes with a degree of autonomy, moving within its environment, to perform intended tasks."@en,
        "Actuated mechanism programmable in two or more axes with a degree of autonomy"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom dt:Mechatronicsystem ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasControlSystem ;
            owl:someValuesFrom rb:RobotController ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasMechanicalStructure ;
            owl:someValuesFrom rb:RobotFrame ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom dt:Autonomousagent ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasPowerSource ;
            owl:someValuesFrom dt:PowerSupply ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasSensingCapability ;
            owl:someValuesFrom rb:SensorSystem ],
        dt:AutonomousAgent,
        dt:MechatronicSystem ;
    owl:disjointWith ai:StaticMachine,
        dt:PurelyMechanicalDevice .

ai:Fairness a owl:Class ;
    rdfs:label "Fairness"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0065" ;
    rdfs:comment "Absolute difference in positive prediction rates across groups (0.0 to 1.0)"@en,
        "Composite fairness score from 0.0 (unfair) to 1.0 (fair)"@en,
        "Ratio of positive rates (80% rule: >= 0.8 considered fair)"@en,
        "The property of an AI system whereby it produces equitable outcomes and avoids creating or reinforcing unjustifiable disparities across different demographic groups or individuals, measured through various mathematical definitions and ethical principles."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:BiasMitigation ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:NonDiscrimination ],
        [ a owl:Restriction ;
            owl:onProperty dt:opposes ;
            owl:someValuesFrom ai:Bias ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:BiasDetection ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:EqualTreatment ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:BiasMitigation ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:BiasDetection ],
        [ a owl:Restriction ;
            owl:onProperty dt:opposes ;
            owl:someValuesFrom rb:HarmfulBias ],
        dt:QualityAttribute,
        dt:TrustworthinessDimension ;
    owl:disjointWith ai:Bias .

ai:PositionalEncoding a owl:Class ;
    rdfs:label "Positional Encoding"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0201" ;
    rdfs:comment "A technique for injecting information about the relative or absolute position of tokens in a sequence, essential for transformers since they lack inherent sequential ordering."@en,
        "Technique for injecting position information into token representations, essential for transformers."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enablesCapability ;
            owl:someValuesFrom ai:SequenceOrderModelling ],
        [ a owl:Restriction ;
            owl:onProperty dt:encodesProperty ;
            owl:someValuesFrom dt:SequencePosition ],
        dt:SequenceEncodingTechnique .

ai:T5 a owl:Class ;
    rdfs:label "T5"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0216" ;
    rdfs:comment "Converts all tasks to text-to-text format: input text → output text"@en,
        "Pre-training objective masking contiguous spans of text"@en,
        "Text-to-Text Transfer Transformer: a unified framework that converts all NLP tasks into a text-to-text format, using an encoder-decoder architecture with a span-corruption pre-training objective."@en,
        "Unified framework converting all NLP tasks to text-to-text format using encoder-decoder architecture."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom dt:TextToTextFramework ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasComponent ;
            owl:someValuesFrom ai:Encoder ],
        [ a owl:Restriction ;
            owl:onProperty ai:trainedWith ;
            owl:someValuesFrom dt:SpanCorruption ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasComponent ;
            owl:someValuesFrom ai:Decoder ],
        [ a owl:Restriction ;
            owl:onProperty ai:trainedOn ;
            owl:someValuesFrom dt:C4Dataset ],
        ai:EncoderDecoderArchitecture,
        ai:PreTrainedLanguageModel,
        ai:TransformerArchitecture,
        mv:TransformerArchitecture .

