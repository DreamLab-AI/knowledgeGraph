            owl:someValuesFrom dt:AlertThresholds ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AiLifecycle ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ContinuousImprovement ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:HumanOversight ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Bias ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom ai:AiGovernance ] .

ai:AiUser a owl:Class ;
    rdfs:label "AI User"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0100" ;
    rdfs:comment "An individual or entity who interacts with, relies upon, or is affected by the outputs, decisions, or recommendations of an artificial intelligence system in order to accomplish tasks, make decisions, obtain services, or achieve objectives, either through direct system interaction or indirect exposure to AI-mediated outcomes, encompassing both active users who consciously engage with AI systems and passive subjects whose data is processed or whose circumstances are influenced by AI operations."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:HumanOversight ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Explainability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:Transparency ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:InformedConsent ],
        [ a owl:Restriction ;
            owl:onProperty dt:appliesTo ;
            owl:someValuesFrom dt:UserExperience ] .

ai:DataAugmentationStrategies a owl:Class ;
    rdfs:label "Data Augmentation Strategies"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0286" ;
    rdfs:comment "Techniques that create modified training examples to increase dataset diversity and model robustness."@en,
        "Techniques that create modified versions of training examples to increase dataset diversity and model robustness. Data augmentation strategies apply transformations that preserve label semantics whilst introducing variation, improving generalisation and reducing overfitting."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:introduces ;
            owl:someValuesFrom mv:Variation ],
        [ a owl:Restriction ;
            owl:onProperty dt:improves ;
            owl:someValuesFrom dt:Generalisation ],
        [ a owl:Restriction ;
            owl:onProperty dt:reduces ;
            owl:someValuesFrom dt:Overfitting ],
        [ a owl:Restriction ;
            owl:onProperty dt:increases ;
            owl:someValuesFrom dt:DatasetDiversity ],
        [ a owl:Restriction ;
            owl:onProperty dt:preserves ;
            owl:someValuesFrom dt:LabelSemantics ],
        ai:TrainingTechnique,
        mv:RegularisationApproach .

ai:ExplainableAi a owl:Class ;
    rdfs:label "Explainable AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0296" ;
    rdfs:comment "AI systems designed to provide clear, understandable explanations of their decision-making processes, enabling stakeholders to comprehend how and why specific outputs are generated."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom ai:ModelInterpretability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:InterpretableAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Lime ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Shap ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:AlgorithmicTransparency ] .

ai:MedicalAi a owl:Class ;
    rdfs:label "Medical AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0336" ;
    rdfs:comment "Medical AI refers to the application of artificial intelligence techniques to healthcare and medical domains, encompassing clinical decision support, diagnostic imaging analysis, treatment planning, drug discovery, and patient care optimisation. Medical AI systems integrate machine learning, computer vision, natural language processing, and knowledge representation to assist healthcare professionals in diagnosis, prognosis, treatment selection, and outcome prediction whilst maintaining patient s"@en,
        "Medical AI refers to the application of artificial intelligence techniques to healthcare and medical domains, encompassing clinical decision support, diagnostic imaging analysis, treatment planning, drug discovery, and patient care optimisation. Medical AI systems integrate machine learning, computer vision, natural language processing, and knowledge representation to assist healthcare professionals in diagnosis, prognosis, treatment selection, and outcome prediction whilst maintaining patient safety and clinical validity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalImagingAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ExplainableAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PrecisionMedicine ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:UncertaintyQuantification ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalDiagnosisAi ] .

ai:MultiHeadAttention a owl:Class ;
    rdfs:label "Multi Head Attention"@en,
        "Multi-Head Attention"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0198" ;
    rdfs:comment "An extension of attention that uses multiple attention heads operating in parallel on different representation subspaces."@en,
        "An extension of the attention mechanism that allows the model to jointly attend to information from different representation subspaces at different positions, using multiple attention heads in parallel."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:performsOperation ;
            owl:someValuesFrom mv:LinearProjection ],
        [ a owl:Restriction ;
            owl:onProperty dt:usesComponent ;
            owl:someValuesFrom dt:ScaledDotProductAttention ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:AttentionHead ],
        [ a owl:Restriction ;
            owl:onProperty dt:performsOperation ;
            owl:someValuesFrom dt:Concatenation ],
        [ a owl:Restriction ;
            owl:onProperty dt:usesComponent ;
            owl:someValuesFrom ai:ScaledDotProductAttention ],
        [ a owl:Restriction ;
            owl:onProperty dt:enablesCapability ;
            owl:someValuesFrom mv:SubspaceRepresentationLearning ],
        [ a owl:Restriction ;
            owl:onProperty dt:enablesCapability ;
            owl:someValuesFrom mv:ParallelAttentionComputation ],
        ai:AttentionMechanism .

