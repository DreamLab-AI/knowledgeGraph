ai:ClinicalDecisionSupport a owl:Class ;
    rdfs:label "Clinical Decision Support"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0337" ;
    rdfs:comment "Clinical Decision Support (CDS) refers to AI systems that provide healthcare professionals with patient-specific assessments, recommendations, and information to support clinical decision-making at the point of care. CDS systems integrate patient data, medical knowledge bases, clinical guidelines, and evidence-based protocols to assist in diagnosis, treatment selection, medication management, and care coordination whilst maintaining clinician autonomy and clinical judgement."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalDiagnosisAi ],
