ai:AutonomousNavigation a owl:Class ;
    rdfs:label "Autonomous Navigation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0355" ;
    rdfs:comment "Autonomous Navigation encompasses the complete system capability for a robot or autonomous agent to move from one location to another without human guidance, integrating perception, localisation, mapping, path planning, obstacle avoidance, and control. Autonomous navigation systems employ SLAM, sensor fusion, and AI-based decision-making to operate in unknown or dynamic environments."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
