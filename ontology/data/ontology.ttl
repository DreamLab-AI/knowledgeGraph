ai:PreTraining a owl:Class ;
    rdfs:label "Pre Training"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0247" ;
    rdfs:comment "Initial training phase where models learn general representations from vast amounts of unlabelled data before task-specific adaptation"@en,
        "The initial training phase where a model learns general representations from large amounts of unlabelled or weakly labelled data before being adapted to specific tasks. Pre-training establishes foundational knowledge that can be transferred across multiple downstream applications."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:precedes ;
            owl:someValuesFrom ai:FineTuning ],
        [ a owl:Restriction ;
            owl:onProperty mv:learns ;
            owl:someValuesFrom dt:GeneralRepresentation ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom mv:SelfSupervisedLearning ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom mv:TransferLearning ],
        [ a owl:Restriction ;
            owl:onProperty ai:trainsOn ;
            owl:someValuesFrom mv:LargeScaleUnlabelledData ],
        [ a owl:Restriction ;
            owl:onProperty dt:creates ;
            owl:someValuesFrom ai:FoundationModel ],
        ai:TrainingTechnique .

ai:Recall a owl:Class ;
    rdfs:label "Recall"@en,
        "Sensitivity"@en,
        "True Positive Rate"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0109" ;
    rdfs:comment "A classification performance metric representing the proportion of actual positive instances that an artificial intelligence model correctly identifies, calculated as the ratio of true positives to all actual positives (true positives plus false negatives), measuring the model's completeness in detecting positive cases, particularly critical in applications where missing positive instances (false negatives) carries significant cost or consequences."@en,
        "A classification performance metric representing the proportion of actual positive instances that an artificial intelligence model correctly identifies."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:complementOf ;
            owl:someValuesFrom dt:FalseNegativeRate ],
        [ a owl:Restriction ;
            owl:onProperty dt:calculatedFrom ;
            owl:someValuesFrom ai:ConfusionMatrix ],
        [ a owl:Restriction ;
            owl:onProperty rb:harmonisedIn ;
            owl:someValuesFrom ai:F1Score ],
        [ a owl:Restriction ;
            owl:onProperty dt:tradeOffWith ;
            owl:someValuesFrom ai:Precision ],
        [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom mv:MachineLearningModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:visualisedVia ;
            owl:someValuesFrom dt:ROCCurve ],
        [ a owl:Restriction ;
            owl:onProperty dt:optimisesFor ;
            owl:someValuesFrom dt:FalseNegativeMinimisation ],
        [ a owl:Restriction ;
            owl:onProperty ai:pairedWith ;
            owl:someValuesFrom dt:Specificity ],
        dt:ClassificationMetric,
        dt:PerformanceMetric .

ai:RewardModel a owl:Class ;
    rdfs:label "Reward Model"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0263" ;
    rdfs:comment "A neural network trained to predict scalar rewards for model outputs based on human feedback, used to provide learning signals in reinforcement learning from human feedback (RLHF). The reward model serves as a proxy for human preferences, enabling efficient optimization without constant human evaluation."@en,
        "Neural network trained to predict scalar rewards for model outputs based on human feedback, enabling efficient optimization in RLHF"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ai:trainedOn ;
            owl:someValuesFrom mv:HumanPreferenceComparisons ],
        [ a owl:Restriction ;
            owl:onProperty dt:servesAsProxyFor ;
            owl:someValuesFrom dt:HumanJudgment ],
        [ a owl:Restriction ;
            owl:onProperty dt:componentOf ;
            owl:someValuesFrom dt:RLHF ],
        [ a owl:Restriction ;
            owl:onProperty mv:providesLearningSignalFor ;
            owl:someValuesFrom mv:ReinforcementLearning ],
        [ a owl:Restriction ;
            owl:onProperty dt:predicts ;
            owl:someValuesFrom mv:ScalarReward ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom ai:BradleyTerryModel ],
        ai:NeuralNetwork .

ai:RootMeanSquareError a owl:Class ;
    rdfs:label "RMSE"@en,
        "Root Mean Square Error"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0115" ;
    rdfs:comment "A regression performance metric representing the square root of the average squared differences between predicted and actual values, calculated by taking the mean of squared prediction errors and then applying the square root, providing a measure of prediction accuracy in the same units as the target variable whilst giving disproportionate weight to larger errors, making it particularly sensitive to outliers and appropriate when large prediction errors are significantly more problematic than small errors."@en,
        "A regression performance metric representing the square root of the average squared differences between predicted and actual values, providing disproportionate weight to larger errors."@en,
        "Mathematical property: RMSE ≥ MAE always holds"@en,
        "RMSE expressed in same units as target variable (unlike MSE which is squared)"@en,
        "RMSE is always non-negative; range [0, ∞) with lower values indicating better performance"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:optimisedBy ;
            owl:someValuesFrom dt:MeanPrediction ],
        [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom ai:RegressionModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:appropriateFor ;
            owl:someValuesFrom dt:QuadraticCostFunction ],
        [ a owl:Restriction ;
            owl:onProperty mv:squareRootOf ;
            owl:someValuesFrom mv:MeanSquaredError ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:StandardDeviationOfResiduals ],
        [ a owl:Restriction ;
            owl:onProperty dt:greaterThanOrEqualTo ;
            owl:someValuesFrom ai:MeanAbsoluteError ],
        [ a owl:Restriction ;
            owl:onProperty mv:hasCharacteristic ;
            owl:someValuesFrom dt:QuadraticErrorPenalty ],
        [ a owl:Restriction ;
            owl:onProperty dt:alternativeTo ;
            owl:someValuesFrom ai:MeanAbsoluteError ],
        dt:ErrorMetric,
        dt:OutlierSensitiveMetric,
        dt:PerformanceMetric,
        dt:RegressionMetric .

bc:Cryptography a owl:Class ;
    rdfs:label "Cryptography"@en ;
    dt:authorityScore 1.0 ;
    dt:maturity "mature" ;
    dcterms:identifier "BC-0026" ;
    rdfs:comment "Cryptography is the mathematical science of securing information through techniques that transform data into unintelligible forms for unauthorized parties whilst enabling authorized parties to reverse the transformation, providing confidentiality, integrity, authentication, and non-repudiation in blockchain systems."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom dt:SecurityTechnology ],
