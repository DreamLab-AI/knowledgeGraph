dt:HardwarePlatformAgnostic a owl:Class ;
    rdfs:label "Hardware Platform Agnostic"@en,
        "Hardware _Platform Agnostic"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "20055",
        "20320" ;
    rdfs:comment "A design principle and architectural quality ensuring that software, systems, or protocols can operate independently of specific hardware architectures or platform implementations. Hardware-/Platform-Agnostic systems achieve portability through abstraction layers that decouple functionality from underlying physical or operating system constraints."@en,
        "capability of a metaverse system to operate across multiple hardware or software platforms without dependency."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enablesCodeReuse ;
            owl:someValuesFrom dt:CrossPlatformCodebase ],
        [ a owl:Restriction ;
            owl:onProperty dt:implementsAbstractionPrinciple ;
            owl:someValuesFrom mv:LayeredArchitecture ],
        [ a owl:Restriction ;
            owl:onProperty dt:avoidsVendorLockin ;
            owl:someValuesFrom dt:VendorNeutrality ],
        [ a owl:Restriction ;
            owl:onProperty dt:providesPortability ;
            owl:someValuesFrom dt:PlatformPortability ],
        [ a owl:Restriction ;
            owl:onProperty mv:supportsVirtualization ;
            owl:someValuesFrom mv:VirtualExecutionEnvironment ],
        [ a owl:Restriction ;
            owl:onProperty mv:minimizesHardwareDependency ;
            owl:someValuesFrom mv:HardwareIndependence ],
        [ a owl:Restriction ;
            owl:onProperty dt:enablesCrossPlatformDevelopment ;
            owl:someValuesFrom mv:MultiTargetFramework ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasAbstractionLayer ;
            owl:someValuesFrom mv:HardwareAbstractionLayer ],
        [ a owl:Restriction ;
            owl:onProperty mv:supportsStandard ;
            owl:someValuesFrom mv:PlatformNeutralStandard ],
        ai:InfrastructureDomain,
        dt:DesignPrinciple,
        dt:InfrastructureLayer,
        mv:ArchitecturalQuality,
        mv:VirtualObject ;
    owl:disjointWith mv:HardwareSpecificOptimization,
        mv:NativeBinaryCompilation .

