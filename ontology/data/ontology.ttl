rb:HumanoidRobot a owl:Class ;
    rdfs:label "Humanoid Robot"@en ;
    dt:authorityScore 0.96 ;
    dt:maturity "mature" ;
    dcterms:identifier "RB-0004" ;
    rdfs:comment "A humanoid robot is a robot whose overall appearance and kinematic structure are based on the human body, typically including a head, torso, two arms, and two legs."@en,
        "Robot with human-like morphology including bipedal locomotion"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom rb:RobotRb0001 ],
        [ a owl:Restriction ;
            owl:onProperty dt:performsBipedalLocomotion ;
            owl:someValuesFrom ai:WalkingGait ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom rb:MobilerobotRb0002 ],
        rb:MobileRobot,
        rb:Robot .

rb:IndustrialRobot a owl:Class ;
    rdfs:label "Industrial Robot"@en ;
    dt:authorityScore 1.0 ;
    dt:maturity "mature" ;
    dcterms:identifier "RB-0005" ;
    rdfs:comment "An industrial robot is an automatically controlled, reprogrammable, multipurpose manipulator programmable in three or more axes, which may be either fixed in place or mobile for use in industrial automation applications."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:operatesIn ;
            owl:someValuesFrom rb:IndustrialEnvironment ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom dt:ManipulatorRb0003 ],
        rb:Manipulator .

ai:AiDevelopment a owl:Class ;
    rdfs:label "AI Development"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0093" ;
    rdfs:comment "The phase of the AI lifecycle encompassing the design, creation, training, and validation of artificial intelligence systems, including activities such as algorithm selection, data preparation, model architecture design, training process execution, hyperparameter optimisation, performance evaluation, and documentation, conducted according to established engineering principles, ethical guidelines, and governance frameworks to produce AI systems suitable for their intended purpose."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:TrainingData ],
        [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom ai:ModelPerformance ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:TrainingData ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AiLifecycle ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:TechnicalExpertise ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:ComputationalResources ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Bias ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Explainability ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom ai:AiGovernance ] .

ai:AiProvider a owl:Class ;
    rdfs:label "AI Provider"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0099" ;
    rdfs:comment "An individual, organisation, or legal entity that develops, produces, or supplies an artificial intelligence system, including responsibility for design decisions, training processes, system capabilities, documentation, and compliance with applicable requirements, and who either places the AI system on the market under their own name or trademark, substantially modifies an existing system, or makes the system available for use, thereby assuming primary accountability for the system's characteris"@en,
        "An individual, organisation, or legal entity that develops, produces, or supplies an artificial intelligence system, including responsibility for design decisions, training processes, system capabilities, documentation, and compliance with applicable requirements, and who either places the AI system on the market under their own name or trademark, substantially modifies an existing system, or makes the system available for use, thereby assuming primary accountability for the system's characteristics, performance, and conformity with regulatory obligations."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:appliesTo ;
            owl:someValuesFrom ai:AiUser ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AiLifecycle ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:RiskManagement ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:ConformityAssessment ] .

ai:ChatbotAI rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:disclosureAt ;
            owl:someValuesFrom mv:InteractionStart ],
        [ a owl:Restriction ;
            owl:onProperty dt:interactsWith ;
            owl:someValuesFrom dt:NaturalPerson ],
        [ a owl:Restriction ;
            owl:onProperty dt:mustInform ;
            owl:someValuesFrom ai:UserOfAIInteraction ],
        ai:LimitedRiskAI .

ai:ConsumerMinimalRiskAI rdfs:subClassOf ai:MinimalRiskAI .

ai:ContinuedPreTraining a owl:Class ;
    rdfs:label "Continued Pre Training"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0248" ;
    rdfs:comment "An intermediate training phase where a pre-trained model undergoes additional pre-training on domain-specific or task-relevant data before fine-tuning. This technique bridges general pre-training and task-specific fine-tuning, adapting model knowledge to particular domains whilst maintaining broad capabilities."@en,
        "Intermediate training phase adapting pre-trained models to specific domains through additional pre-training on domain-relevant unlabelled data"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:precedesPhase ;
            owl:someValuesFrom dt:FineTuning ],
        [ a owl:Restriction ;
            owl:onProperty dt:prevents ;
            owl:someValuesFrom dt:CatastrophicForgetting ],
        [ a owl:Restriction ;
            owl:onProperty dt:followsPhase ;
            owl:someValuesFrom ai:PreTraining ],
        [ a owl:Restriction ;
            owl:onProperty ai:trainsOn ;
            owl:someValuesFrom ai:DomainSpecificUnlabelledData ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:DomainAdaptation ],
        [ a owl:Restriction ;
            owl:onProperty ai:maintains ;
            owl:someValuesFrom dt:GeneralCapabilities ],
        ai:TrainingTechnique .

ai:CreativeMinimalRiskAI rdfs:subClassOf ai:MinimalRiskAI .

ai:FullFineTuning a owl:Class ;
    rdfs:label "Full Fine Tuning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0257" ;
    rdfs:comment "A fine-tuning approach that updates all parameters of a pre-trained model during adaptation to a downstream task. Full fine-tuning provides maximum flexibility and performance potential but requires substantial computational resources and memory."@en,
        "Fine-tuning approach updating all parameters of pre-trained model, providing maximum flexibility and performance potential at high computational cost"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:creates ;
            owl:someValuesFrom ai:NewModelCopy ],
        [ a owl:Restriction ;
            owl:onProperty dt:risks ;
            owl:someValuesFrom dt:CatastrophicForgetting ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:SubstantialComputationalResources ],
        [ a owl:Restriction ;
            owl:onProperty dt:updates ;
            owl:someValuesFrom mv:AllModelParameters ],
        ai:FineTuning .

ai:HumanInTheLoop a owl:Class ;
    rdfs:label "Human in the Loop"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0097" ;
    rdfs:comment "A design pattern and operational approach for artificial intelligence systems in which human judgment, decision-making, or validation is integrated as an essential component of the AI system's decision cycle, requiring active human participation at critical points before AI-generated outputs are finalised or actions are executed, thereby ensuring meaningful human control, accountability, and the application of human values and contextual understanding to consequential AI-assisted decisions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ErrorCorrection ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:EthicalAlignment ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AutomationBias ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:HumanOversight ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Explainability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:RiskManagement ] .

ai:MachineTranslation a owl:Class ;
    rdfs:label "Machine Translation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0367" ;
    rdfs:comment "Machine Translation is the automated translation of text or speech from one natural language to another using neural network models, particularly transformer-based sequence-to-sequence architectures. Modern neural machine translation systems (Google Translate, DeepL, NLLB) achieve near-human translation quality through pre-training on massive multilingual corpora, attention mechanisms, and cross-lingual transfer learning."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom ai:SequencetosequenceModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:NaturalLanguageProcessing ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Transformer ],
        dt:NaturalLanguageProcessing .

ai:MedicalDiagnosisAi a owl:Class ;
    rdfs:label "Medical Diagnosis AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0343" ;
    rdfs:comment "Medical Diagnosis AI refers to artificial intelligence systems that automate or assist in the diagnostic process by analysing patient symptoms, medical history, laboratory results, imaging findings, and other clinical data to generate differential diagnoses, diagnostic hypotheses, and diagnostic recommendations. These systems employ machine learning, knowledge representation, and clinical reasoning algorithms validated against expert physician performance."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ClinicalDecisionSupport ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:TreatmentPlanningAi ] .

ai:MedicalImagingAi a owl:Class ;
    rdfs:label "Medical Imaging AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0338" ;
    rdfs:comment "Medical Imaging AI encompasses artificial intelligence systems designed to analyse, interpret, and enhance medical images including radiological scans, pathology slides, and other diagnostic imaging modalities. These systems employ deep learning architectures, particularly convolutional neural networks, to perform tasks such as lesion detection, disease classification, segmentation of anatomical structures, and quantitative image analysis whilst adhering to clinical validation standards and regu"@en,
        "Medical Imaging AI encompasses artificial intelligence systems designed to analyse, interpret, and enhance medical images including radiological scans, pathology slides, and other diagnostic imaging modalities. These systems employ deep learning architectures, particularly convolutional neural networks, to perform tasks such as lesion detection, disease classification, segmentation of anatomical structures, and quantitative image analysis whilst adhering to clinical validation standards and regulatory requirements."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:PathologyAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:RadiologyAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ComputerVision ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ConvolutionalNeuralNetwork ] .

ai:ModelInterpretability a owl:Class ;
    rdfs:label "Model Interpretability"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0298" ;
    rdfs:comment "The degree to which a human can understand the cause-effect relationships within a machine learning model's decision-making process, encompassing both the model's internal mechanisms and the reasoning behind specific predictions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Shap ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:FeatureImportance ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ExplainableAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:InterpretableAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Lime ] .

ai:NamedEntityRecognition a owl:Class ;
    rdfs:label "Named Entity Recognition"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0368" ;
    rdfs:comment "Named Entity Recognition (NER) is the NLP task of identifying and classifying named entities (persons, organisations, locations, dates, quantities) within unstructured text into predefined categories. NER systems employ transformer-based models (BERT, RoBERTa) with sequence labelling architectures (CRF, BiLSTM-CRF) to extract structured information from documents, enabling information extraction, knowledge graph construction, and semantic search."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:InformationExtraction ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Bert ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:NaturalLanguageProcessing ],
        dt:NaturalLanguageProcessing .

ai:PanopticSegmentation a owl:Class ;
    rdfs:label "Panoptic Segmentation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0361" ;
    rdfs:comment "Panoptic Segmentation unifies semantic segmentation and instance segmentation by assigning every pixel both a class label and an instance ID, providing a complete scene understanding with \"thing\" classes (countable objects) and \"stuff\" classes (amorphous regions). Panoptic segmentation offers holistic scene parsing for applications requiring comprehensive visual understanding such as autonomous driving and robotics."@en,
        "Panoptic Segmentation unifies semantic segmentation and instance segmentation by assigning every pixel both a class label and an instance ID, providing a complete scene understanding with \\"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:InstanceSegmentation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:SemanticSegmentation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:SceneUnderstanding ],
        ai:ComputerVision .

ai:RadiologyAi a owl:Class ;
    rdfs:label "Radiology AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0339" ;
    rdfs:comment "Radiology AI refers to artificial intelligence systems specifically designed for the interpretation and analysis of radiological imaging modalities including X-ray, computed tomography (CT), magnetic resonance imaging (MRI), and ultrasound. These systems automate detection, classification, and quantification tasks whilst integrating with PACS workflows and providing radiologist-level diagnostic performance validated through clinical trials."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:PathologyAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalImagingAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Dicom ] .

ai:SocialScoringAI rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:leadsTo ;
            owl:someValuesFrom dt:DetrimentalTreatment ],
        [ a owl:Restriction ;
            owl:onProperty dt:evaluatesBasedOn ;
            owl:someValuesFrom dt:SocialBehaviour ],
        [ a owl:Restriction ;
            owl:onProperty dt:evaluatesBasedOn ;
            owl:someValuesFrom mv:PersonalCharacteristics ],
        ai:ProhibitedAIPractice .

ai:TransparencyOecd a owl:Class ;
    rdfs:label "Transparency (OECD)"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0161" ;
    rdfs:comment "AI actors should commit to transparency and responsible disclosure regarding AI systems, providing sufficient information to enable people to understand AI outcomes, challenge decisions and participate meaningfully in AI-influenced processes."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:Contestability ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:InformedDecisionMaking ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:Trust ] .

ai:TreatmentPlanningAi a owl:Class ;
    rdfs:label "Treatment Planning AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0344" ;
    rdfs:comment "Treatment Planning AI encompasses artificial intelligence systems that optimise therapeutic interventions through automated treatment selection, dosage optimisation, radiation therapy planning, surgical planning, and personalised care pathway design. These systems integrate patient-specific data, treatment guidelines, outcome predictions, and resource constraints to generate evidence-based, individualised treatment plans."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:RadiationTherapy ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalDiagnosisAi ] .

