ai:HealthcareAnalytics a owl:Class ;
    rdfs:label "Healthcare Analytics"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0345" ;
    rdfs:comment "Healthcare Analytics applies artificial intelligence and data science to healthcare data for population health management, operational efficiency optimisation, clinical outcome prediction, resource allocation, and healthcare policy decision-making. These systems analyse electronic health records, claims data, public health data, and operational metrics to derive actionable insights for healthcare improvement."@en ;
