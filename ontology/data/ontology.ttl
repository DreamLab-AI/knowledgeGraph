            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:ObjectDetection ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PanopticSegmentation ],
        ai:ComputerVision .

