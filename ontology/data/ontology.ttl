            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:Redress ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:EffectiveGovernance ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
