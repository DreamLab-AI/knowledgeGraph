        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Chatbot ],
        dt:NaturalLanguageProcessing .

ai:DifferentialPrivacy a owl:Class ;
    rdfs:label "Differential Privacy"@en ;
    dt:authorityScore 0.95 ;
    dt:maturity "mature" ;
    dcterms:identifier "AI-0416" ;
    rdfs:comment "Differential Privacy is a mathematical framework providing provable privacy guarantees by adding carefully calibrated noise to data queries or model outputs, ensuring that the presence or absence of any single individual's data has negligible impact on analysis results. This technique provides formal privacy protection through the epsilon (ε) parameter quantifying privacy loss, where smaller ε values indicate stronger privacy guarantees (typically ε ≤ 1.0 for high-privacy scenarios), with differential privacy satisfied when for all datasets D1 and D2 differing by one record and all possible outputs S, P(M(D1) ∈ S) ≤ exp(ε) × P(M(D2) ∈ S). Implementation mechanisms include the Laplace mechanism adding noise proportional to query sensitivity for numeric queries, the Gaussian mechanism suitable for more complex settings with delta (δ) parameter allowing negligible probability of privacy breach, the exponential mechanism for non-numeric outputs selecting results proportional to their utility, and composition theorems tracking cumulative privacy loss across multiple queries (sequential composition where total ε_total = Σε_i, advanced composition providing tighter bounds). The 2024-2025 period witnessed differential privacy evolve from theoretical framework to practical requirement with the U.S. Census Bureau's 2020 Census deployment demonstrating feasibility at national scale, technology companies including Apple, Microsoft, and Meta deploying differential privacy for telemetry and usage analytics proving strong privacy need not preclude valuable aggregate insights, and academic consensus emerging around epsilon budgets with ε ≤ 1.0 for high-privacy scenarios. Applications span statistical databases enabling privacy-preserving aggregate statistics, machine learning protecting training data through differentially private stochastic gradient descent (DP-SGD), and federated learning scenarios adding noise to model updates before aggregation, though challenges include computational overhead of noise addition, utility degradation particularly for complex queries or small datasets, and privacy budget exhaustion requiring careful allocation across queries."@en .

ai:EncoderDecoderArchitecture a owl:Class ;
    rdfs:label "Encoder Decoder Architecture"@en,
        "Encoder-Decoder Architecture"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0207" ;
    rdfs:comment "A neural network structure consisting of an encoder that processes the input sequence and a decoder that generates the output sequence, commonly used in sequence-to-sequence tasks."@en,
        "Decoder attends to encoder outputs via cross-attention mechanism"@en,
        "Neural network structure with encoder processing input and decoder generating output sequences."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:hasComponent ;
            owl:someValuesFrom dt:Encoder ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasComponent ;
            owl:someValuesFrom ai:Decoder ],
        [ a owl:Restriction ;
            owl:onProperty dt:implementsMechanism ;
            owl:someValuesFrom ai:CrossAttention ],
        mv:NeuralNetworkArchitecture .

ai:EthicalAi a owl:Class ;
    rdfs:label "Ethical AI"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0103" ;
    rdfs:comment "The development, deployment, and use of artificial intelligence systems in accordance with moral principles and values that respect human dignity, rights, and wellbeing, incorporating considerations of fairness, transparency, accountability, privacy, safety, and beneficence throughout the AI lifecycle, whilst promoting human flourishing, social justice, and the common good through deliberate design choices, governance mechanisms, and operational practices that embed ethical reasoning into AI sys"@en,
        "The development, deployment, and use of artificial intelligence systems in accordance with moral principles and values that respect human dignity, rights, and wellbeing, incorporating considerations of fairness, transparency, accountability, privacy, safety, and beneficence throughout the AI lifecycle, whilst promoting human flourishing, social justice, and the common good through deliberate design choices, governance mechanisms, and operational practices that embed ethical reasoning into AI system functioning and organisational decision-making."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:TrustworthyAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ResponsibleAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:TrustworthyAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:ResponsibleAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:HumanRights ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:AiGovernance ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:Transparency ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:StakeholderEngagement ] .

ai:InstanceSegmentation a owl:Class ;
    rdfs:label "Instance Segmentation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0360" ;
    rdfs:comment "Instance Segmentation extends object detection by predicting precise pixel-level masks for each individual object instance, combining object detection with semantic segmentation to delineate exact boundaries of distinct objects. Instance segmentation models (Mask R-CNN, YOLACT, SOLOv2) enable fine-grained object localisation essential for robotics manipulation, autonomous driving, and medical image analysis."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:SemanticSegmentation ],
