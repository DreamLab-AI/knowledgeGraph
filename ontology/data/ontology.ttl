    dt:maturity "draft" ;
    dcterms:identifier "AI-0210" ;
    rdfs:comment "A mechanism that controls which positions in a sequence can attend to which other positions, typically implemented by adding large negative values before softmax to effectively zero out unwanted attention weights."@en,
        "Mechanism controlling which positions can attend to which other positions in attention computation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:controls ;
