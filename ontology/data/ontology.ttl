            owl:someValuesFrom dt:TestData ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom mv:StandardsDocumentation ] .

dt:VirtualProductionVp a owl:Class ;
    rdfs:label "Virtual Production (VP)"@en ;
    dt:maturity "mature" ;
    dcterms:identifier "20198" ;
    rdfs:comment "Production technique blending real and virtual scenes using XR and real-time rendering for film, broadcast, and immersive content creation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
