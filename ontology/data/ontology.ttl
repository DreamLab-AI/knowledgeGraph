dt:AccessibilityAuditTool a owl:Class ;
    rdfs:label "Accessibility Audit Tool"@en ;
    dt:maturity "mature" ;
    dcterms:identifier "20119" ;
    rdfs:comment "An automated software utility that verifies compliance with accessibility standards (such as WCAG) in XR environments, identifying barriers for users with disabilities."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:InclusiveDesign ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom dt:TestingProtocol ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:AutomatedTestingEngine ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ComplianceVerification ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:ReportGenerator ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom ai:QualityAssuranceToolchain ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom mv:AccessibilityStandards ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:TestingFramework ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:WcagValidator ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom mv:XrAccessibilityStandards ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:UserInterfaceAnalyzer ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:AccessibilityReporting ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom dt:WcagGuidelines ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:RegulatoryCompliance ],
