        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:HumanOversight ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:RiskManagement ],
