ai:Accuracy a owl:Class ;
    rdfs:label "Accuracy"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0107" ;
    rdfs:comment "A classification performance metric representing the proportion of correct predictions made by an artificial intelligence model across all instances in a dataset, calculated as the ratio of the sum of true positives and true negatives to the total number of predictions, providing an aggregate measure of overall model correctness but potentially obscuring performance disparities across classes, particularly in datasets with imbalanced class distributions or asymmetric misclassification costs."@en,
        "A classification performance metric representing the proportion of correct predictions made by an artificial intelligence model across all instances in a dataset."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:hasLimitation ;
            owl:someValuesFrom dt:ClassImbalanceSensitivity ],
        [ a owl:Restriction ;
            owl:onProperty dt:complementedBy ;
            owl:someValuesFrom dt:Precision ],
        [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom mv:MachineLearningModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:complementedBy ;
            owl:someValuesFrom dt:F1Score ],
        [ a owl:Restriction ;
            owl:onProperty dt:calculatedFrom ;
            owl:someValuesFrom dt:ConfusionMatrix ],
        [ a owl:Restriction ;
            owl:onProperty dt:complementedBy ;
            owl:someValuesFrom dt:Recall ],
        dt:ClassificationMetric,
        dt:PerformanceMetric .

ai:AiGovernanceFramework a owl:Class ;
    rdfs:label "AI Governance Framework"@en ;
    dt:authorityScore 0.95 ;
    dt:maturity "mature" ;
    dcterms:identifier "AI-0387" ;
    rdfs:comment "AI Governance Framework is a comprehensive organizational structure that establishes oversight mechanisms, ethical principles, accountability structures, and policy frameworks for responsible development and deployment of artificial intelligence systems. This framework defines roles and responsibilities across the AI lifecycle, implements risk management processes, ensures regulatory compliance, and establishes decision-making authority for AI-related activities. Key components include executive leadership commitment and sponsorship, cross-functional governance committees or AI ethics boards, documented policies covering AI development standards, risk assessment procedures, ethical guidelines, and data governance protocols, incident response and escalation procedures, compliance monitoring and audit mechanisms, and continuous improvement processes. An effective AI governance framework integrates with existing organizational governance structures (IT governance, data governance, enterprise risk management) while addressing AI-specific concerns including algorithmic accountability, fairness and bias mitigation, transparency and explainability requirements, human oversight provisions, and stakeholder engagement. Implementation aligns with international standards including ISO/IEC 42001:2023 AI Management Systems, OECD AI Principles, EU AI Act governance requirements, and sector-specific regulations, providing a systematic approach to managing AI risks and ensuring trustworthy AI deployment that protects organizational interests and stakeholder rights."@en .

ai:BytePairEncoding a owl:Class ;
    rdfs:label "Byte Pair Encoding"@en,
        "Byte-Pair Encoding"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0233" ;
    rdfs:comment "A subword tokenisation algorithm that iteratively merges most frequent pairs to build vocabulary."@en,
        "A subword tokenisation algorithm that iteratively merges the most frequent pairs of characters or character sequences to build a vocabulary, originally developed for data compression."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:creates ;
            owl:someValuesFrom bc:VariableLengthTokens ],
        [ a owl:Restriction ;
            owl:onProperty dt:produces ;
            owl:someValuesFrom mv:Vocabulary ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom dt:FrequencyBasedMerging ],
        bc:SubwordTokenisation,
        bc:TokenisationAlgorithm ;
    owl:disjointWith dt:SentencePiece,
        dt:WordPiece .

ai:ContrastiveLearning a owl:Class ;
    rdfs:label "Contrastive Learning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0283" ;
    rdfs:comment "A self-supervised learning approach that learns representations by contrasting positive pairs (similar samples) against negative pairs (dissimilar samples). Contrastive learning enables models to learn powerful representations without explicit labels by pushing similar examples together and dissimilar ones apart in embedding space."@en,
        "Self-supervised learning approach that learns representations by contrasting positive pairs against negative pairs."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom ai:NegativePairs ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom ai:PositivePairs ],
        [ a owl:Restriction ;
            owl:onProperty dt:optimises ;
            owl:someValuesFrom dt:EmbeddingSpace ],
        [ a owl:Restriction ;
            owl:onProperty dt:criticallyUses ;
            owl:someValuesFrom ai:DataAugmentationStrategies ],
        ai:TrainingTechnique,
        mv:RepresentationLearning,
        mv:SelfSupervisedLearning .

ai:FeatureImportance a owl:Class ;
    rdfs:label "Feature Importance"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0303" ;
    rdfs:comment "Quantitative measures indicating the relative contribution or influence of individual input features on a machine learning model's predictions, enabling identification of the most critical variables driving model outputs."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:FeatureAttribution ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Shap ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:FeatureSelection ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PermutationImportance ],
        [ a owl:Restriction ;
            owl:onProperty mv:hasPart ;
            owl:someValuesFrom mv:PartialDependencePlot ] .

ai:LimitedRiskAI rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:subjectOnlyTo ;
            owl:someValuesFrom mv:TransparencyObligation ],
        [ a owl:Restriction ;
            owl:onProperty dt:obligates ;
            owl:someValuesFrom mv:ProviderTransparencyDuty ],
        [ a owl:Restriction ;
            owl:onProperty dt:obligates ;
            owl:someValuesFrom dt:DeployerDisclosureDuty ],
        ai:AISystem .

ai:MeanAbsoluteError a owl:Class ;
    rdfs:label "MAE"@en,
        "Mean Absolute Error"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0114" ;
    rdfs:comment "A regression performance metric representing the average magnitude of errors between predicted and actual values, calculated as the arithmetic mean of absolute differences between predictions and ground truth across all instances, providing an intuitive measure of prediction accuracy in the same units as the target variable, treating all errors equally regardless of direction, and being less sensitive to outliers than squared error metrics."@en,
        "A regression performance metric representing the average magnitude of errors between predicted and actual values, calculated as the arithmetic mean of absolute differences."@en,
        "MAE expressed in same units as target variable, enabling intuitive interpretation"@en,
        "MAE is always non-negative; range [0, ∞) with lower values indicating better performance"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:alternativeTo ;
            owl:someValuesFrom mv:RootMeanSquareError ],
        [ a owl:Restriction ;
            owl:onProperty dt:appropriateFor ;
            owl:someValuesFrom mv:LinearCostFunction ],
        [ a owl:Restriction ;
            owl:onProperty mv:hasCharacteristic ;
            owl:someValuesFrom mv:LinearErrorPenalty ],
        [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom ai:RegressionModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:optimisedBy ;
            owl:someValuesFrom dt:MedianPrediction ],
        [ a owl:Restriction ;
            owl:onProperty dt:lessSensitiveToOutliersThan ;
            owl:someValuesFrom mv:RootMeanSquareError ],
        dt:ErrorMetric,
        dt:OutlierRobustMetric,
        dt:PerformanceMetric,
        dt:RegressionMetric .

ai:ResidualConnection a owl:Class ;
    rdfs:label "Residual Connection"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0204" ;
    rdfs:comment "A neural network connection that adds the input of a layer to its output, enabling gradient flow in deep networks and facilitating training of very deep architectures."@en,
        "Connection that adds layer input to its output, enabling gradient flow in deep networks."@en,
        "Each sublayer has residual connection followed by layer normalisation"@en,
        "Original architecture introducing residual connections"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:facilitates ;
            owl:someValuesFrom mv:ResidualFunctionLearning ],
        [ a owl:Restriction ;
            owl:onProperty dt:performsOperation ;
            owl:someValuesFrom dt:ElementwiseAddition ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:DeepNetworkTraining ],
        [ a owl:Restriction ;
            owl:onProperty dt:performsOperation ;
            owl:someValuesFrom dt:IdentityMapping ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:DirectGradientFlow ],
        mv:ArchitectureComponent .

bc:ConsensusMechanism a owl:Class ;
    rdfs:label "Consensus Mechanism"@en ;
    dt:authorityScore 1.0 ;
    dt:maturity "mature" ;
    dcterms:identifier "BC-0051" ;
    rdfs:comment "A consensus mechanism is a fault-tolerant protocol that enables distributed network nodes to agree on a single, consistent state of a distributed ledger despite the presence of faulty or malicious nodes, ensuring all valid transactions are recorded in the same order across all nodes without requiring a trusted central authority."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom dt:DistributedProtocol ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom dt:AgreementProtocol ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom dt:FaultToleranceSystem ] .

bc:NetworkTopology a owl:Class ;
    rdfs:label "Network Topology"@en ;
    dt:authorityScore 0.95 ;
    dt:maturity "mature" ;
    dcterms:identifier "BC-0087" ;
    rdfs:comment "Node connection structure within blockchain systems, providing essential functionality for distributed ledger technology operations and properties."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom bc:BlockchainEntity ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom ai:Networkcomponent ] .

dt:AUC rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty mv:summarises ;
            owl:someValuesFrom dt:ROCCurve ],
        [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom mv:MachineLearningModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:equivalentTo ;
            owl:someValuesFrom dt:WilcoxonMannWhitneyStatistic ],
        [ a owl:Restriction ;
            owl:onProperty mv:areaUnderCurve ;
            owl:someValuesFrom dt:ROCCurve ],
