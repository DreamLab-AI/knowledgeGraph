        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:RenderEngine ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:CameraTrackingSystem ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:RealTimeRendering ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom dt:BroadcastProduction ],
        [ a owl:Restriction ;
