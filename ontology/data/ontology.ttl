ai:Chatbot a owl:Class ;
    rdfs:label "Chatbot"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0373" ;
    rdfs:comment "A Chatbot is a software application that simulates human conversation through text or voice interactions, automating customer service, information retrieval, and task completion through natural language dialogue. Chatbots range from rule-based systems to sophisticated AI-powered conversational agents employing large language models, intent classification, and dialogue management to provide responsive, context-aware interactions across messaging platforms, websites, and voice interfaces."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:DialogueSystem ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:NaturalLanguageProcessing ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:VirtualAssistant ] .

ai:CoTraining a owl:Class ;
    rdfs:label "Co Training"@en,
        "Co-Training"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0282" ;
    rdfs:comment "A semi-supervised learning technique where multiple models with different views train each other through mutual teaching."@en,
        "A semi-supervised learning technique where two or more models with different views of the data train each other by labelling unlabelled examples. Co-training leverages complementary feature sets or model architectures to improve performance through mutual teaching."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom mv:ComplementaryViews ],
        [ a owl:Restriction ;
            owl:onProperty dt:reduces ;
            owl:someValuesFrom dt:LabellingRequirements ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom ai:MultipleModels ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom dt:PseudoLabelling ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom dt:ViewDiversity ],
        ai:TrainingTechnique,
        mv:SemiSupervisedLearning ;
    owl:disjointWith ai:SelfTraining .

ai:ContextWindow a owl:Class ;
    rdfs:label "Context Window"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0238" ;
    rdfs:comment "The maximum sequence length that a model can process at once, determining available prior context."@en,
        "The maximum sequence length that a model can process at once, determining how much prior context it can consider during generation or understanding tasks."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatesTo ;
            owl:someValuesFrom dt:MaximumSequenceLength ],
        [ a owl:Restriction ;
            owl:onProperty ai:constrains ;
            owl:someValuesFrom ai:AttentionMechanism ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatesTo ;
            owl:someValuesFrom dt:PositionalEncoding ],
        [ a owl:Restriction ;
            owl:onProperty dt:tradesOff ;
            owl:someValuesFrom dt:ComputationalCost ],
        [ a owl:Restriction ;
            owl:onProperty dt:tradesOff ;
            owl:someValuesFrom dt:MemoryUsage ],
        mv:ArchitecturalConstraint,
        mv:ModelHyperparameter .

ai:EarlyStopping a owl:Class ;
    rdfs:label "Early Stopping"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0290" ;
    rdfs:comment "A regularisation technique that terminates training when validation performance stops improving, preventing overfitting by avoiding overtraining on the training set. Early stopping balances training progress against generalisation to unseen data."@en,
        "Regularisation technique that terminates training when validation performance stops improving to prevent overfitting."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:ValidationSet ],
        [ a owl:Restriction ;
            owl:onProperty dt:prevents ;
            owl:someValuesFrom dt:Overfitting ],
        [ a owl:Restriction ;
            owl:onProperty dt:prevents ;
            owl:someValuesFrom ai:Overtraining ],
        [ a owl:Restriction ;
            owl:onProperty dt:balances ;
            owl:someValuesFrom ai:TrainingProgress ],
        [ a owl:Restriction ;
            owl:onProperty dt:monitors ;
            owl:someValuesFrom dt:ValidationPerformance ],
        [ a owl:Restriction ;
            owl:onProperty dt:balances ;
            owl:someValuesFrom dt:Generalisation ],
        ai:TrainingStrategy,
        mv:RegularisationTechnique .

ai:GenerativeAdversarialNetwork a owl:Class ;
    rdfs:label "Generative Adversarial Network"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0035" ;
    rdfs:comment "### Primary Definition"@en .

ai:GlobalExplanation a owl:Class ;
    rdfs:label "Global Explanation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0302" ;
    rdfs:comment "Interpretability techniques that characterise the overall behaviour, decision-making patterns, and feature importance of a machine learning model across its entire input space, rather than explaining individual predictions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Shap ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:IndividualConditionalExpectation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PermutationImportance ],
        [ a owl:Restriction ;
            owl:onProperty mv:hasPart ;
            owl:someValuesFrom mv:PartialDependencePlot ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:FeatureImportance ] .

ai:GradientClipping a owl:Class ;
    rdfs:label "Gradient Clipping"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0294" ;
    rdfs:comment "A technique that limits the magnitude of gradients during backpropagation to prevent exploding gradients and training instability. Gradient clipping rescales gradients when their norm exceeds a threshold, enabling stable training of deep networks, especially recurrent architectures."@en,
        "Technique that limits gradient magnitude during backpropagation to prevent exploding gradients and training instability."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:criticalFor ;
            owl:someValuesFrom ai:RecurrentNeuralNetworks ],
        [ a owl:Restriction ;
            owl:onProperty dt:criticalFor ;
            owl:someValuesFrom mv:LargeLanguageModels ],
        [ a owl:Restriction ;
            owl:onProperty dt:stabilises ;
            owl:someValuesFrom ai:Training ],
        [ a owl:Restriction ;
            owl:onProperty dt:prevents ;
            owl:someValuesFrom ai:TrainingInstability ],
        [ a owl:Restriction ;
            owl:onProperty dt:prevents ;
            owl:someValuesFrom dt:ExplodingGradients ],
        [ a owl:Restriction ;
            owl:onProperty dt:appliedDuring ;
            owl:someValuesFrom ai:Backpropagation ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:StableDeepNetworkTraining ],
        ai:TrainingTechnique,
        dt:StabilisationMethod .

ai:HumanOversight a owl:Class ;
    rdfs:label "Human Oversight"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0096" ;
    rdfs:comment "The continuous or periodic involvement of competent human actors in the governance, development, deployment, and operation of artificial intelligence systems, exercising meaningful control, judgment, and intervention capabilities to ensure AI system decisions and actions remain aligned with human values, ethical principles, legal requirements, and intended purposes, with particular emphasis on preventing, detecting, and correcting harmful or inappropriate AI behaviours through informed human dec"@en,
        "The continuous or periodic involvement of competent human actors in the governance, development, deployment, and operation of artificial intelligence systems, exercising meaningful control, judgment, and intervention capabilities to ensure AI system decisions and actions remain aligned with human values, ethical principles, legal requirements, and intended purposes, with particular emphasis on preventing, detecting, and correcting harmful or inappropriate AI behaviours through informed human decision-making authority."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-required-by ;
            owl:someValuesFrom ai:AiGovernance ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AutomationBias ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ContinuousImprovement ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ErrorCorrection ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:Transparency ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Explainability ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-required-by ;
            owl:someValuesFrom ai:AiLifecycle ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ResponsibleAi ] .

ai:ImageGeneration a owl:Class ;
    rdfs:label "Image Generation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0362" ;
    rdfs:comment "Image Generation is the synthesis of realistic or stylised images using generative AI models including Generative Adversarial Networks (GANs), Variational Autoencoders (VAEs), and Diffusion Models. Modern image generation systems (DALL-E, Stable Diffusion, Midjourney) produce high-fidelity images from text descriptions, sketches, or latent representations, enabling creative applications, data augmentation, and content creation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Texttoimage ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:GenerativeAdversarialNetwork ],
        [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom ai:DiffusionModel ],
        ai:ComputerVision .

ai:IntrinsicInterpretability a owl:Class ;
    rdfs:label "Intrinsic Interpretability"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0300" ;
    rdfs:comment "The inherent transparency and understandability of a machine learning model's architecture and decision-making process, achieved through model design rather than external explanation techniques, enabling direct human comprehension without additional interpretability methods."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:RuleExtraction ],
        [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom ai:BlackBoxModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:DecisionTreeApproximation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:InterpretableAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PosthocExplanation ] .

ai:LanguageModeling a owl:Class ;
    rdfs:label "Language Modeling"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0375" ;
    rdfs:comment "Language Modeling is the fundamental NLP task of learning probability distributions over sequences of words or tokens to predict the likelihood of text sequences and generate plausible continuations. Language models underpin virtually all modern NLP applications through pre-training on massive text corpora, capturing syntactic structure, semantic relationships, and world knowledge that transfer to downstream tasks including text generation, translation, question answering, and code synthesis."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Gpt ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:TextGeneration ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Transformer ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:NaturalLanguageProcessing ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Bert ] .

ai:MachineLearning a owl:Class ;
    rdfs:label "Machine Learning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0002" ;
    rdfs:comment "### Primary Definition"@en,
        "Process enabling computational systems to understand data and gain knowledge from experience without being explicitly programmed"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:requiresInput ;
            owl:someValuesFrom ai:TrainingData ],
        [ a owl:Restriction ;
            owl:onProperty dt:produces ;
            owl:someValuesFrom ai:Model ],
        [ a owl:Restriction ;
            owl:onProperty dt:employs ;
            owl:someValuesFrom mv:LearningAlgorithm ],
        [ a owl:Restriction ;
            owl:onProperty dt:demonstrates ;
            owl:someValuesFrom dt:PerformanceImprovement ],
        ai:ArtificialIntelligence,
        dt:ComputationalStatistics ;
    owl:disjointWith ai:RuleBasedAI,
        dt:ExpertSystem .

ai:MotionPlanning a owl:Class ;
    rdfs:label "Motion Planning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0352" ;
    rdfs:comment "Motion Planning extends path planning by incorporating robot dynamics, control constraints, and time-parametrisation to generate dynamically feasible trajectories that account for velocity, acceleration, jerk, and actuator limitations. Motion planning produces executable control sequences that guide robots and autonomous vehicles from initial to goal states whilst satisfying kinodynamic constraints and optimising performance metrics."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PathPlanning ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:ControlTheory ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:TrajectoryOptimisation ] .

ai:ParameterEfficientFineTuning a owl:Class ;
    rdfs:label "Parameter Efficient Fine Tuning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0256" ;
    rdfs:comment "Training techniques that update only a small subset of model parameters during fine-tuning, reducing computational and memory requirements whilst maintaining comparable performance to full fine-tuning. PEFT methods enable adaptation of large models with limited resources."@en,
        "Training techniques updating only a small subset of model parameters whilst maintaining comparable performance to full fine-tuning"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:reduces ;
            owl:someValuesFrom dt:ComputationalRequirements ],
        [ a owl:Restriction ;
            owl:onProperty dt:freezes ;
            owl:someValuesFrom ai:PreTrainedWeights ],
        [ a owl:Restriction ;
            owl:onProperty dt:updatesSubset ;
            owl:someValuesFrom ai:ModelParameters ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:MultiTaskDeployment ],
        ai:TrainingTechnique .

ai:PostHocExplanation a owl:Class ;
    rdfs:label "Post Hoc Explanation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0299" ;
    rdfs:comment "Interpretability techniques applied after a machine learning model has been trained, providing explanations for model behaviour and predictions without modifying the model's architecture or requiring retraining."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:FeatureAttribution ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:IntrinsicInterpretability ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Lime ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Shap ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:CounterfactualExplanation ] .

ai:Precision a owl:Class ;
    rdfs:label "Positive Predictive Value"@en,
        "Precision"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0108" ;
    rdfs:comment "A classification performance metric representing the proportion of positive predictions made by an artificial intelligence model that are actually correct, calculated as the ratio of true positives to all positive predictions (true positives plus false positives), measuring the model's ability to avoid false alarms and providing critical insight into prediction reliability, particularly important in applications where the cost or consequence of false positive errors is significant."@en,
        "A classification performance metric representing the proportion of positive predictions made by an artificial intelligence model that are actually correct."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom mv:MachineLearningModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:calculatedFrom ;
            owl:someValuesFrom ai:ConfusionMatrix ],
        [ a owl:Restriction ;
            owl:onProperty dt:tradeOffWith ;
            owl:someValuesFrom dt:Recall ],
        [ a owl:Restriction ;
            owl:onProperty dt:optimisesFor ;
            owl:someValuesFrom dt:FalsePositiveMinimisation ],
        [ a owl:Restriction ;
            owl:onProperty rb:harmonisedIn ;
            owl:someValuesFrom ai:F1Score ],
        dt:ClassificationMetric,
        dt:PerformanceMetric,
        dt:ThresholdDependentMetric .

ai:PreferenceLearning a owl:Class ;
    rdfs:label "Preference Learning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0264" ;
    rdfs:comment "A machine learning paradigm that learns from comparative judgments (e.g., \"A is better than B\") rather than absolute labels or demonstrations. Preference learning enables training models to align with human values by learning from rankings and comparisons, which are often easier for humans to provide than absolute ratings or demonstrations."@en,
        "Machine learning paradigm learning from comparative judgments rather than absolute labels, enabling natural alignment with human values"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:foundationFor ;
            owl:someValuesFrom dt:DirectPreferenceOptimization ],
        [ a owl:Restriction ;
            owl:onProperty mv:learnsFrom ;
            owl:someValuesFrom mv:ComparativeJudgments ],
        [ a owl:Restriction ;
            owl:onProperty dt:captures ;
            owl:someValuesFrom dt:RelativePreferences ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom ai:BradleyTerryModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:AlignmentTraining ],
        [ a owl:Restriction ;
            owl:onProperty dt:foundationFor ;
            owl:someValuesFrom dt:RLHF ],
        mv:MachineLearningParadigm .

ai:PrefixTuning a owl:Class ;
    rdfs:label "Prefix Tuning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0252" ;
    rdfs:comment "A parameter-efficient fine-tuning technique that prepends trainable continuous vectors (prefixes) to the key and value matrices at each transformer layer, whilst keeping the pre-trained model parameters frozen. Unlike prompt tuning which only modifies input embeddings, prefix tuning affects attention computation at every layer."@en,
        "Parameter-efficient fine-tuning prepending trainable continuous vectors to key and value matrices at each transformer layer"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:appliesAtEach ;
            owl:someValuesFrom dt:TransformerLayer ],
        [ a owl:Restriction ;
            owl:onProperty dt:modifies ;
            owl:someValuesFrom dt:KeyValueMatrices ],
        [ a owl:Restriction ;
            owl:onProperty dt:freezes ;
            owl:someValuesFrom mv:PreTrainedParameters ],
        [ a owl:Restriction ;
            owl:onProperty dt:prepends ;
            owl:someValuesFrom ai:TrainablePrefixes ],
        [ a owl:Restriction ;
            owl:onProperty dt:affects ;
            owl:someValuesFrom dt:AttentionComputation ],
        ai:ParameterEfficientFineTuning .

ai:PromptTuning a owl:Class ;
    rdfs:label "Prompt Tuning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0251" ;
    rdfs:comment "A parameter-efficient fine-tuning method that learns continuous prompt embeddings prepended to the input whilst keeping the pre-trained model frozen. Prompt tuning optimises task-specific soft prompts in the embedding space rather than modifying model weights."@en,
        "Parameter-efficient fine-tuning method learning continuous prompt embeddings prepended to input whilst keeping pre-trained model frozen"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:freezes ;
            owl:someValuesFrom mv:PreTrainedModelParameters ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:MultiTaskDeployment ],
        [ a owl:Restriction ;
            owl:onProperty mv:learns ;
            owl:someValuesFrom dt:ContinuousPromptEmbeddings ],
        [ a owl:Restriction ;
            owl:onProperty dt:optimizesIn ;
            owl:someValuesFrom dt:EmbeddingSpace ],
        ai:ParameterEfficientFineTuning .

ai:RealTimeBiometricIdentificationAI rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:operatesIn ;
            owl:someValuesFrom dt:PubliclyAccessibleSpace ],
        [ a owl:Restriction ;
            owl:onProperty dt:usedBy ;
            owl:someValuesFrom dt:LawEnforcement ],
        [ a owl:Restriction ;
            owl:onProperty dt:performs ;
            owl:someValuesFrom dt:LiveFacialRecognition ],
        ai:ProhibitedAIPractice .

ai:RiskMitigation a owl:Class ;
    rdfs:label "Risk Mitigation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0079" ;
    rdfs:comment "Actions taken to reduce the likelihood or impact of identified AI risks through technical, organizational, or procedural controls, implemented throughout the AI lifecycle to achieve acceptable risk levels."@en .

ai:SentimentAnalysis a owl:Class ;
    rdfs:label "Sentiment Analysis"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0369" ;
    rdfs:comment "Sentiment Analysis is the NLP task of determining the emotional tone, attitude, or opinion expressed in text, classifying content as positive, negative, or neutral, and extracting fine-grained emotional attributes. Sentiment analysis employs transformer-based classifiers to enable applications in social media monitoring, customer feedback analysis, market research, and brand reputation management."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom dt:EmotionalAnalyticsEngine ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom bc:OpinionMining ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-dependency-of ;
            owl:someValuesFrom dt:MetaversePsychologyProfile ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:NaturalLanguageProcessing ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:TextClassification ],
        ai:NaturalLanguageProcessing .

ai:SupervisedFineTuning a owl:Class ;
    rdfs:label "Supervised Fine Tuning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0250" ;
    rdfs:comment "A fine-tuning approach that uses labelled training data to adapt a pre-trained model to specific tasks, optimising performance through supervised learning on input-output pairs. Supervised fine-tuning (SFT) represents the most direct path from general pre-training to task-specific capability."@en,
        "Fine-tuning approach using labelled training data to adapt pre-trained models, forming the first stage in multi-stage alignment pipelines"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:optimizesVia ;
            owl:someValuesFrom dt:SupervisedLoss ],
        [ a owl:Restriction ;
            owl:onProperty dt:establishesBaseline ;
            owl:someValuesFrom dt:TaskPerformance ],
        [ a owl:Restriction ;
            owl:onProperty dt:precedesPhase ;
            owl:someValuesFrom dt:RLHF ],
        [ a owl:Restriction ;
            owl:onProperty dt:requiresData ;
            owl:someValuesFrom ai:LabelledInputOutputPairs ],
        [ a owl:Restriction ;
            owl:onProperty dt:formsStage ;
            owl:someValuesFrom dt:AlignmentPipeline ],
        ai:FineTuning .

ai:SyntheticContentGenerationAI rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:mustLabel ;
            owl:someValuesFrom dt:GeneratedContent ],
        [ a owl:Restriction ;
            owl:onProperty dt:requiresLabelling ;
            owl:someValuesFrom ai:MachineReadableFormat ],
        [ a owl:Restriction ;
            owl:onProperty dt:generates ;
            owl:someValuesFrom dt:SyntheticContent ],
        [ a owl:Restriction ;
            owl:onProperty dt:requiresLabelling ;
            owl:someValuesFrom dt:HumanPerceivableFormat ],
        ai:LimitedRiskAI .

ai:Training a owl:Class ;
    rdfs:label "Training"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0041" ;
    rdfs:comment "### Primary Definition"@en .

ai:TransformerArchitecture a owl:Class ;
    rdfs:label "Transformer Architecture"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0196" ;
    rdfs:comment "A neural network architecture based solely on attention mechanisms, dispensing with recurrence and convolutions entirely, designed for sequence-to-sequence tasks."@en,
        "A neural network architecture based solely on attention mechanisms, dispensing with recurrence and convolutions entirely."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:PositionalEncoding ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:MultiHeadAttention ],
        [ a owl:Restriction ;
            owl:onProperty dt:enablesCapability ;
            owl:someValuesFrom mv:ParallelSequenceProcessing ],
        [ a owl:Restriction ;
            owl:onProperty dt:enablesCapability ;
            owl:someValuesFrom ai:LongRangeDependencyModelling ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:FeedForwardNetwork ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:ResidualConnection ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:SelfAttention ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom ai:LayerNormalisation ],
        mv:NeuralNetworkArchitecture .

bc:CensorshipResistance a owl:Class ;
    rdfs:label "Censorship Resistance"@en ;
    dt:authorityScore 0.95 ;
    dt:maturity "mature" ;
    dcterms:identifier "BC-0086" ;
    rdfs:comment "Transaction inclusion guarantee within blockchain systems, providing essential functionality for distributed ledger technology operations and properties."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom bc:BlockchainEntity ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom ai:Networkcomponent ] .

bc:Transaction a owl:Class ;
    rdfs:label "Transaction"@en ;
    dt:authorityScore 0.95 ;
    dt:maturity "mature" ;
    dcterms:identifier "BC-0006" ;
    rdfs:comment "State-changing operation on blockchain within blockchain systems, providing essential functionality for distributed ledger technology operations and properties."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom dt:Distributeddatastructure ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-subclass-of ;
            owl:someValuesFrom bc:BlockchainEntity ] .

bc:VerifiableCredentials a owl:Class ;
    rdfs:label "Verifiable Credentials"@en ;
