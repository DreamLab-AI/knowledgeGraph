        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom dt:FilmProductionWorkflow ] .

dt:ZeroTrustArchitectureZta a owl:Class ;
    rdfs:label "Zero-Trust Architecture (ZTA)"@en ;
    dt:maturity "mature" ;
    dcterms:identifier "20189" ;
    rdfs:comment "Security model requiring continuous verification of all entities and transactions with least-privilege access enforcement, eliminating implicit trust within metaverse network boundaries."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:PolicyDecisionPoint ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:DeviceAuthentication ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:PolicyEnforcementPoint ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:NetworkSegmentation ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom dt:AuthorizationFramework ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:InsiderThreatMitigation ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:BreachContainment ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:LeastPrivilegeAccessControl ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:ContinuousVerification ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:DynamicAccessControl ],
        [ a owl:Restriction ;
            owl:onProperty dt:has-part ;
            owl:someValuesFrom dt:PolicyEngine ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom dt:CybersecurityFramework ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom bc:IdentityVerification ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:Encryption ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom dt:AuthenticationProtocol ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom dt:SecurityInformationAndEventManagementSiem ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom mv:SecurityArchitecture ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ThreatDetection ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:LoggingAndMonitoring ],
        [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
            owl:someValuesFrom dt:AccessControlSystem ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:Microsegmentation ] .

dt:bridges-to a owl:ObjectProperty ;
    rdfs:label "bridges to" .

dt:dependsOn a owl:ObjectProperty .

dt:optimisedBy a owl:ObjectProperty .

ai:AdapterModules a owl:Class ;
    rdfs:label "Adapter Modules"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0253" ;
    rdfs:comment "Small neural network modules inserted between transformer layers providing task-specific adaptation whilst keeping base model frozen"@en,
        "Small neural network modules inserted between transformer layers that are trained whilst keeping the original model frozen. Adapter modules provide a parameter-efficient way to adapt pre-trained models to new tasks by learning task-specific transformations without modifying the base model."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom dt:ResidualConnection ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:MultiTaskDeployment ],
        [ a owl:Restriction ;
            owl:onProperty dt:implements ;
            owl:someValuesFrom mv:BottleneckArchitecture ],
        [ a owl:Restriction ;
            owl:onProperty dt:insertsBetween ;
            owl:someValuesFrom dt:TransformerLayers ],
        [ a owl:Restriction ;
            owl:onProperty dt:freezes ;
            owl:someValuesFrom mv:OriginalModelParameters ],
        mv:ParameterEfficientFineTuning .

ai:Adas a owl:Class ;
    rdfs:label "ADAS"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0348" ;
    rdfs:comment "Advanced Driver Assistance Systems (ADAS) are electronic systems that assist vehicle operators with driving and parking functions through automated technologies including adaptive cruise control, lane keeping assist, automatic emergency braking, blind spot detection, and parking assistance. ADAS represents SAE Level 1-2 automation, providing driver support whilst requiring continuous driver supervision and intervention capability."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:AutonomousVehicle ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom rb:SensorFusion ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PerceptionSystem ],
        dt:DriverAssistanceTechnology .

ai:AdversarialTesting a owl:Class ;
    rdfs:label "Adversarial Testing"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0271" ;
    rdfs:comment "Testing methodology that deliberately attempts to cause AI system failures through adversarial inputs and challenging scenarios."@en,
        "Testing methodology that deliberately attempts to cause AI system failures through adversarial inputs, edge cases, and challenging scenarios. Adversarial testing helps identify robustness issues, safety vulnerabilities, and alignment failures before deployment."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:identifies ;
            owl:someValuesFrom dt:SafetyVulnerabilities ],
        [ a owl:Restriction ;
            owl:onProperty dt:identifies ;
            owl:someValuesFrom ai:AlignmentFailures ],
        [ a owl:Restriction ;
            owl:onProperty dt:includes ;
            owl:someValuesFrom dt:RedTeaming ],
        [ a owl:Restriction ;
            owl:onProperty dt:identifies ;
            owl:someValuesFrom dt:RobustnessIssues ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom dt:EdgeCaseTesting ],
        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom mv:AdversarialExamples ],
        dt:SafetyEvaluation,
        dt:TestingMethodology .

ai:AiOperator a owl:Class ;
    rdfs:label "AI Operator"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0098" ;
    rdfs:comment "An individual or organisational entity responsible for the operational management, monitoring, and control of an artificial intelligence system during its deployment and use, including activities such as configuring system parameters, overseeing system performance, responding to incidents, coordinating maintenance, exercising human oversight, and ensuring the AI system operates safely, effectively, and in accordance with established policies, procedures, and regulatory requirements within specif"@en,
        "An individual or organisational entity responsible for the operational management, monitoring, and control of an artificial intelligence system during its deployment and use, including activities such as configuring system parameters, overseeing system performance, responding to incidents, coordinating maintenance, exercising human oversight, and ensuring the AI system operates safely, effectively, and in accordance with established policies, procedures, and regulatory requirements within specific operational contexts."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AiMonitoring ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:Training ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:OngoingSupport ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom dt:CompetenceDevelopment ],
        [ a owl:Restriction ;
            owl:onProperty dt:appliesTo ;
            owl:someValuesFrom ai:AiUser ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:HumanOversight ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Humanintheloop ] .

ai:AttentionHead a owl:Class ;
    rdfs:label "Attention Head"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0242" ;
    rdfs:comment "Hidden dimension is split amongst multiple heads"@en,
        "One of multiple parallel attention mechanisms in multi-head attention, each potentially learning different types of relationships and patterns in the input sequence."@en,
        "One of multiple parallel attention mechanisms in multi-head attention, learning different relationship patterns."@en,
        "Research shows many attention heads can be pruned without significant performance degradation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty mv:learns ;
            owl:someValuesFrom dt:AttentionPattern ],
        [ a owl:Restriction ;
            owl:onProperty dt:implementsMechanism ;
            owl:someValuesFrom dt:ScaledDotProductAttention ],
        dt:AttentionMechanismComponent .

ai:AutonomousVehicle a owl:Class ;
    rdfs:label "Autonomous Vehicle"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0346" ;
    rdfs:comment "An Autonomous Vehicle is a self-driving vehicle capable of navigating and operating without human intervention, employing artificial intelligence for perception, localisation, path planning, motion control, and decision-making. Autonomous vehicles integrate sensor fusion, computer vision, deep learning, and control algorithms to achieve SAE automation levels ranging from Level 1 (driver assistance) to Level 5 (full automation)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:Adas ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom rb:SensorFusion ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:SelfdrivingCar ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PathPlanning ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:PerceptionSystem ] .

ai:CausalAttention a owl:Class ;
    rdfs:label "Causal Attention"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0209" ;
    rdfs:comment "An attention mechanism where each position can only attend to earlier positions in the sequence, preventing information flow from future tokens, essential for autoregressive generation."@en,
        "Attention mechanism preventing information flow from future tokens, essential for autoregressive generation."@en,
        "Contrasts with bidirectional attention in BERT-style encoders"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:usesComponent ;
            owl:someValuesFrom ai:AttentionMask ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:AutoregressiveGeneration ],
        [ a owl:Restriction ;
            owl:onProperty dt:implementsPattern ;
            owl:someValuesFrom dt:CausalMasking ],
        ai:AttentionMechanism,
        dt:SelfAttention .

ai:CurriculumLearning a owl:Class ;
    rdfs:label "Curriculum Learning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0260" ;
    rdfs:comment "A training strategy that presents examples to the model in a meaningful order, typically from easy to difficult, mimicking how humans learn. Curriculum learning can improve convergence speed, final performance, and generalization by structuring the learning progression."@en,
        "Training strategy presenting examples in meaningful order, typically from easy to difficult, to improve convergence and generalization"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:follows ;
            owl:someValuesFrom dt:EasyToDifficultProgression ],
        [ a owl:Restriction ;
            owl:onProperty dt:presents ;
            owl:someValuesFrom dt:ExamplesInMeaningfulOrder ],
        [ a owl:Restriction ;
            owl:onProperty dt:improves ;
            owl:someValuesFrom dt:Generalization ],
        [ a owl:Restriction ;
            owl:onProperty dt:mimics ;
            owl:someValuesFrom mv:HumanLearningProcesses ],
        [ a owl:Restriction ;
            owl:onProperty dt:improves ;
            owl:someValuesFrom dt:ConvergenceSpeed ],
        ai:TrainingTechnique .

ai:DataBias rdfs:subClassOf ai:Bias .

ai:DirectPreferenceOptimisation a owl:Class ;
    rdfs:label "Direct Preference Optimisation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0266" ;
    rdfs:comment "Alignment method that directly uses preference data without reward models or RL, simplifying RLHF."@en,
        "An alignment method that directly uses preference data to fine-tune language models without training a separate reward model or using reinforcement learning, offering a simpler alternative to RLHF. DPO optimizes the policy directly on preference comparisons through a reparameterisation of the reward model objective."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:optimisesOn ;
            owl:someValuesFrom ai:PreferencePairs ],
        [ a owl:Restriction ;
            owl:onProperty dt:eliminates ;
            owl:someValuesFrom mv:ReinforcementLearning ],
        [ a owl:Restriction ;
            owl:onProperty dt:eliminates ;
            owl:someValuesFrom mv:RewardModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:simplerThan ;
            owl:someValuesFrom dt:RLHF ],
        [ a owl:Restriction ;
            owl:onProperty dt:moreStableThan ;
            owl:someValuesFrom dt:RLHF ],
        [ a owl:Restriction ;
            owl:onProperty mv:startsFrom ;
            owl:someValuesFrom dt:SupervisedFineTuning ],
        ai:TrainingTechnique,
        dt:AlignmentMethod,
        mv:PreferenceLearning .

ai:Encoder a owl:Class ;
    rdfs:label "Encoder"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0205" ;
    rdfs:comment "Component that processes input sequence to produce contextualised representations."@en,
        "The component in an encoder-decoder architecture that processes the input sequence and produces contextualised representations, using self-attention and feed-forward layers."@en,
        "Transformer models using only encoder for bidirectional understanding"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:creates ;
            owl:someValuesFrom dt:SemanticEncoding ],
        [ a owl:Restriction ;
            owl:onProperty dt:takesInput ;
            owl:someValuesFrom bc:TokenSequence ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfLayers ;
            owl:someValuesFrom dt:EncoderLayer ],
        [ a owl:Restriction ;
            owl:onProperty dt:produces ;
            owl:someValuesFrom dt:ContextualisedRepresentation ],
        mv:TransformerArchitectureComponent .

ai:Explainability a owl:Class ;
    rdfs:label "Explainability"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0063" ;
    rdfs:comment "The extent to which an AI system's decision-making processes, outputs, and behaviors can be understood and articulated in human-comprehensible terms, enabling stakeholders to grasp how and why specific outcomes were produced."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:ContestabilityAi0043 ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:AccountabilityAi0068 ] .

ai:FeedForwardNetwork a owl:Class ;
    rdfs:label "Feed Forward Network"@en,
        "Feed-Forward Network"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0202" ;
    rdfs:comment "A fully connected neural network layer applied to each position separately and identically in a transformer, typically consisting of two linear transformations with a non-linear activation function."@en,
        "Position-wise fully connected network with two linear transformations and non-linear activation."@en,
        "Sparse alternative to FFN in some transformer architectures"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:usesActivation ;
            owl:someValuesFrom mv:NonLinearActivation ],
        [ a owl:Restriction ;
            owl:onProperty dt:consistsOfComponent ;
            owl:someValuesFrom mv:LinearTransformation ],
        ai:NeuralNetworkLayer .

ai:HumanFeedback a owl:Class ;
    rdfs:label "Human Feedback"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0262" ;
    rdfs:comment "Information provided by human evaluators about model outputs enabling alignment of AI systems with human preferences and values"@en,
        "Information provided by human evaluators about model outputs, typically in the form of rankings, ratings, demonstrations, or corrections. Human feedback serves as the training signal for aligning AI systems with human preferences and values, enabling learning of complex objectives difficult to specify formally."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:providedBy ;
            owl:someValuesFrom dt:HumanEvaluators ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasModalities ;
            owl:someValuesFrom dt:Rankings ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:AlignmentTraining ],
        [ a owl:Restriction ;
            owl:onProperty ai:formsTrainingSignalFor ;
            owl:someValuesFrom dt:RLHF ],
        [ a owl:Restriction ;
            owl:onProperty dt:captures ;
            owl:someValuesFrom dt:HumanPreferences ],
        [ a owl:Restriction ;
            owl:onProperty dt:hasModalities ;
            owl:someValuesFrom dt:Demonstrations ],
        ai:TrainingSignal .

ai:InstructionTuning a owl:Class ;
    rdfs:label "Instruction Tuning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0249" ;
    rdfs:comment "A fine-tuning technique that trains language models to follow natural language instructions by training on diverse instruction-response pairs. Instruction tuning enables models to generalise to new tasks described through instructions without task-specific training data."@en,
        "Fine-tuning technique training language models to follow natural language instructions by learning from diverse instruction-response pairs"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ZeroShotTaskPerformance ],
        [ a owl:Restriction ;
            owl:onProperty dt:oftCombinedWith ;
            owl:someValuesFrom dt:RLHF ],
        [ a owl:Restriction ;
            owl:onProperty dt:improves ;
            owl:someValuesFrom dt:InstructionFollowing ],
        [ a owl:Restriction ;
            owl:onProperty dt:reduces ;
            owl:someValuesFrom rb:HarmfulOutputs ],
        [ a owl:Restriction ;
            owl:onProperty ai:trainsOn ;
            owl:someValuesFrom ai:InstructionResponsePairs ],
        [ a owl:Restriction ;
            owl:onProperty dt:improves ;
            owl:someValuesFrom dt:AlignmentWithUserIntent ],
        ai:FineTuning .

ai:LayerNormalisation a owl:Class ;
    rdfs:label "Layer Normalisation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0203" ;
    rdfs:comment "A normalisation technique that normalises activations across the feature dimension for each example independently, stabilising deep network training."@en,
        "Layer normalisation applied after attention/FFN sublayers"@en,
        "Layer normalisation applied before attention/FFN sublayers"@en,
        "Normalisation technique across features for each example, stabilising deep network training."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty mv:hasParameter ;
            owl:someValuesFrom mv:ShiftParameter ],
        [ a owl:Restriction ;
            owl:onProperty mv:hasParameter ;
            owl:someValuesFrom mv:ScaleParameter ],
        [ a owl:Restriction ;
            owl:onProperty dt:provides ;
            owl:someValuesFrom ai:TrainingStability ],
        dt:NormalisationTechnique .

ai:LocalExplanation a owl:Class ;
    rdfs:label "Local Explanation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0301" ;
    rdfs:comment "Interpretability techniques that explain individual model predictions for specific instances, providing insight into why a particular input produced a given output without necessarily characterising the model's global behaviour."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:IntegratedGradients ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:CounterfactualExplanation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:FeatureAttribution ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Shap ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Lime ] .

ai:MultiTaskLearning a owl:Class ;
    rdfs:label "Multi Task Learning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0259" ;
    rdfs:comment "A machine learning paradigm where a model is trained simultaneously on multiple related tasks, sharing representations across tasks to improve generalization and efficiency. Multi-task learning leverages task relatedness to learn better features than training on each task independently."@en,
        "Machine learning paradigm training models simultaneously on multiple related tasks to leverage task relatedness and improve generalization"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:KnowledgeTransfer ],
        [ a owl:Restriction ;
            owl:onProperty dt:actsAs ;
            owl:someValuesFrom mv:Regularization ],
        [ a owl:Restriction ;
            owl:onProperty dt:improves ;
            owl:someValuesFrom dt:Generalization ],
        [ a owl:Restriction ;
            owl:onProperty ai:trainsSimultaneouslyOn ;
            owl:someValuesFrom dt:MultipleRelatedTasks ],
        [ a owl:Restriction ;
            owl:onProperty mv:shares ;
            owl:someValuesFrom dt:RepresentationsAcrossTasks ],
        ai:TrainingTechnique .

ai:PerceptionSystem a owl:Class ;
    rdfs:label "Perception System"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0349" ;
    rdfs:comment "A Perception System is the sensor processing and environmental understanding component of autonomous systems that interprets raw sensor data to build a coherent representation of the surrounding environment, including object detection, classification, tracking, localisation, and scene understanding. Perception systems fuse data from multiple sensor modalities (camera, lidar, radar) to create robust environmental models for autonomous decision-making."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ComputerVision ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
            owl:someValuesFrom ai:AiAgentSystem ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ObjectDetection ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom rb:SensorFusion ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-part-of ;
