ai:ImageClassification a owl:Class ;
    rdfs:label "Image Classification"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0357" ;
    rdfs:comment "Image Classification is the computer vision task of assigning a categorical label to an entire image from a predefined set of classes, determining what is depicted in the image as a whole. Modern image classification employs deep convolutional neural networks (ResNet, EfficientNet, Vision Transformers) trained on large-scale datasets (ImageNet) to achieve human-level or super-human performance on diverse visual recognition tasks."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
