<http://disruption.org/ontology/unified> a owl:Ontology ;
    rdfs:label "Unified Disruptive Technologies Ontology"@en ;
    dcterms:created "2025-11-09"^^xsd:date ;
    dcterms:creator "Logseq Ontology Tools - Header Extractor" ;
    rdfs:comment "Multi-domain ontology with cross-domain bridges integrating AI, Blockchain, Metaverse, and Robotics. Generated from OntologyBlock headers only."@en ;
    owl:versionInfo "1.1.0" .

ai:Backpropagation a owl:Class ;
    rdfs:label "Backpropagation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0043" ;
    rdfs:comment "### Primary Definition"@en .

ai:Bart a owl:Class ;
    rdfs:label "BART"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0222" ;
    rdfs:comment "Bidirectional and Auto-Regressive Transformers: a denoising autoencoder combining bidirectional encoding with autoregressive decoding."@en,
        "Bidirectional and Auto-Regressive Transformers: a denoising autoencoder for pre-training sequence-to-sequence models, combining bidirectional encoding (like BERT) with autoregressive decoding (like GPT)."@en .

ai:GPAIWithSystemicRisk rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:meets ;
            owl:someValuesFrom dt:HighImpactCapabilityThreshold ],
        ai:GeneralPurposeAIModel .

ai:GraphNeuralNetwork a owl:Class ;
    rdfs:label "Graph Neural Network"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0040" ;
    rdfs:comment "### Primary Definition"@en .

ai:ImageToImageTranslation a owl:Class ;
    rdfs:label "Image to Image Translation"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0363" ;
    rdfs:comment "Image-to-Image Translation transforms images from one visual domain to another whilst preserving content structure, converting between image modalities such as sketch-to-photo, day-to-night, satellite-to-map, or style transfer between artistic styles. Image translation models (Pix2Pix, CycleGAN, StyleGAN) employ conditional generation and adversarial learning to learn mappings between paired or unpaired image domains."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:GenerativeAdversarialNetwork ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:StyleTransfer ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ImageGeneration ],
        dt:ComputerVisionImageGeneration .

ai:MembershipInference a owl:Class ;
    rdfs:label "Membership Inference"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0087" ;
    rdfs:comment "A privacy attack that determines whether a specific data point was included in a model's training dataset by analyzing the model's behavior on that input, potentially revealing sensitive information about individuals' participation in datasets."@en .

ai:ModelExtraction a owl:Class ;
    rdfs:label "Model Extraction"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0090" ;
    rdfs:comment "An attack where adversaries reconstruct a functionally equivalent or similar machine learning model by systematically querying a target model and training a substitute model on the collected input-output pairs, enabling theft of intellectual property, privacy violations, and subsequent attacks."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:ModelInversion ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:MembershipInference ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom mv:AdversarialAttacks ] .

ai:ModelInversion a owl:Class ;
    rdfs:label "Model Inversion"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0086" ;
    rdfs:comment "An inference-time privacy attack that reconstructs sensitive training data or attributes from a trained model by exploiting model outputs, predictions, or internal representations, potentially revealing confidential information about individuals in the training dataset."@en .

ai:ModelParameters a owl:Class ;
    rdfs:label "Model Parameters"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0051" ;
    rdfs:comment "### Primary Definition"@en .

ai:PathPlanning a owl:Class ;
    rdfs:label "Path Planning"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0351" ;
    rdfs:comment "Path Planning is the algorithmic process of determining an optimal or feasible geometric path from a start location to a goal location whilst avoiding obstacles, adhering to constraints, and optimising objectives such as distance, time, safety, or energy consumption. Path planning algorithms range from graph-based methods (A*, Dijkstra) to sampling-based methods (RRT, PRM) and optimisation-based methods for autonomous navigation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:TrajectoryOptimisation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MotionPlanning ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:AutonomousNavigation ] .

ai:PrecisionMedicine a owl:Class ;
    rdfs:label "Precision Medicine"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0342" ;
    rdfs:comment "Precision Medicine utilises artificial intelligence to tailor medical treatment to individual patient characteristics, integrating genomic data, clinical information, lifestyle factors, and environmental data to predict treatment response, identify optimal therapies, and stratify patient populations. AI-driven precision medicine enables personalised diagnosis, prognosis, and therapeutic selection based on multi-omic data integration and predictive modelling."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:MedicalAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:Genomics ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:DrugDiscoveryAi ] .

ai:RecurrentNeuralNetwork a owl:Class ;
    rdfs:label "Recurrent Neural Network"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0033" ;
    rdfs:comment "### Primary Definition"@en ;
    owl:disjointWith dt:Transformer .

ai:RuleBasedAI owl:disjointWith dt:ExpertSystem .

ai:Safety a owl:Class ;
    rdfs:label "Safety"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0070" ;
    rdfs:comment "The condition whereby an AI system operates without causing unacceptable risk of physical injury, harm to human health or well-being, damage to property, or harm to the environment, achieved through hazard identification, risk assessment, and implementation of appropriate safeguards."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:RiskAssessmentAi0079 ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom mv:HazardAnalysis ] .

ai:SceneUnderstanding a owl:Class ;
    rdfs:label "Scene Understanding"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0354" ;
    rdfs:comment "Scene Understanding is the high-level semantic interpretation of visual and sensor data to comprehend the structure, context, objects, relationships, and dynamics of an environment. For autonomous systems, scene understanding involves recognising road types, lane configurations, traffic situations, pedestrian intentions, and environmental conditions to enable contextually appropriate decision-making beyond simple object detection."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ComputerVision ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:PerceptionSystem ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:SemanticSegmentation ] .

ai:SelfTraining a owl:Class ;
    rdfs:label "Self Training"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0281" ;
    rdfs:comment "A semi-supervised learning technique where a model is iteratively improved by training on its own high-confidence predictions on unlabelled data. Self-training enables learning from large amounts of unlabelled data by using the model's own predictions as pseudo-labels."@en .

ai:StyleTransfer a owl:Class ;
    rdfs:label "Style Transfer"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0364" ;
    rdfs:comment "Style Transfer is the technique of applying the artistic style of one image (style image) to the content of another image (content image), creating a new image that combines content from one source with the aesthetic style of another. Neural style transfer employs convolutional neural networks to separate and recombine content and style representations, enabling artistic rendering, photo enhancement, and creative visual effects."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom dt:ImagetoimageTranslation ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ImageGeneration ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:ConvolutionalNeuralNetwork ],
        dt:ComputerVisionImageGeneration .

ai:Transparency a owl:Class ;
    rdfs:label "Transparency"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0062" ;
    rdfs:comment "The property of an AI system whereby relevant information about the system's design, operation, capabilities, limitations, and decision-making processes is accessible and understandable to appropriate stakeholders."@en,
        "Transparency level ranging from 0.0 (opaque) to 1.0 (fully transparent)"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:ExplainabilityAi0064 ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:Explainability ],
        [ a owl:Restriction ;
            owl:onProperty dt:supports ;
            owl:someValuesFrom ai:Accountability ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:AccountabilityAi0068 ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom ai:AiImpactAssessment ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom dt:ConsentManagement ],
        dt:QualityAttribute,
        dt:TrustworthinessDimension .

