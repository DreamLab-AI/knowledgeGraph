ai:CrossAttention a owl:Class ;
    rdfs:label "Cross Attention"@en,
        "Cross-Attention"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0208" ;
    rdfs:comment "An attention mechanism where queries come from one sequence whilst keys and values come from a different sequence, enabling information flow between the encoder and decoder in sequence-to-sequence models."@en,
        "Attention mechanism where queries come from one sequence while keys and values come from another."@en,
        "Unlike self-attention, cross-attention connects different sequences for information flow"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:ContextualIntegration ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom dt:InformationTransfer ],
        ai:AttentionMechanism ;
    owl:disjointWith dt:SelfAttention .

ai:F1Score a owl:Class ;
    rdfs:label "F1 Score"@en ;
    dt:maturity "draft" ;
    dcterms:identifier "AI-0110" ;
    rdfs:comment "A classification performance metric representing the harmonic mean of precision and recall, providing a single score that balances a model's ability to avoid false positives (precision) with its ability to avoid false negatives (recall), calculated to give equal weight to both metrics whilst penalising extreme imbalances, particularly useful for comparing models or setting decision thresholds when both prediction reliability and completeness are important and when class distributions are imbalanced."@en,
        "A classification performance metric representing the harmonic mean of precision and recall, providing a single score that balances a model's ability to avoid false positives with its ability to avoid false negatives."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:combinesMetrics ;
            owl:someValuesFrom dt:Precision ],
        [ a owl:Restriction ;
            owl:onProperty dt:measuresPerformanceOf ;
            owl:someValuesFrom mv:MachineLearningModel ],
        [ a owl:Restriction ;
            owl:onProperty dt:appropriateFor ;
            owl:someValuesFrom dt:ImbalancedDataset ],
        [ a owl:Restriction ;
            owl:onProperty dt:calculatedVia ;
            owl:someValuesFrom rb:HarmonicMean ],
        [ a owl:Restriction ;
            owl:onProperty mv:hasCharacteristic ;
            owl:someValuesFrom dt:EqualPrecisionRecallWeighting ],
        [ a owl:Restriction ;
            owl:onProperty dt:combinesMetrics ;
            owl:someValuesFrom dt:Recall ],
        [ a owl:Restriction ;
            owl:onProperty dt:calculatedFrom ;
            owl:someValuesFrom ai:ConfusionMatrix ],
        dt:ClassificationMetric,
        dt:CompositeMetric,
        dt:FBetaScore,
        dt:PerformanceMetric .

