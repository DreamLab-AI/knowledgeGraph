        [ a owl:Restriction ;
            owl:onProperty dt:uses ;
            owl:someValuesFrom dt:GeneratorDiscriminatorPattern ],
        ai:PreTrainedLanguageModel,
        mv:TransformerArchitecture ;
    owl:disjointWith dt:BERT,
        dt:RoBERTa .

