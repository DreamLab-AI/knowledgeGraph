dt:AiGeneratedContentDisclosure a owl:Class ;
    rdfs:label "AI-Generated Content Disclosure"@en ;
    dt:maturity "mature" ;
    dcterms:identifier "20221" ;
    rdfs:comment "Mandatory transparency requirement specifying that content created wholly or partially by AI systems must be explicitly labeled with origin metadata for user awareness and regulatory compliance."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dt:depends-on ;
