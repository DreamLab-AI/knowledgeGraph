            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom ai:EthicalAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:enables ;
            owl:someValuesFrom ai:SocialLicenceForAi ],
        [ a owl:Restriction ;
            owl:onProperty dt:requires ;
            owl:someValuesFrom ai:AiImpactAssessment ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom mv:Transparency ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom ai:AiGovernanceFramework ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom dt:EtsiDomainEthicsLaw ],
        [ a owl:Restriction ;
            owl:onProperty dt:is-enabled-by ;
            owl:someValuesFrom dt:EthicsLawLayer ],
        [ a owl:Restriction ;
            owl:onProperty dt:relatedTo ;
            owl:someValuesFrom ai:EthicalAi ],
        [ a owl:Restriction ;
